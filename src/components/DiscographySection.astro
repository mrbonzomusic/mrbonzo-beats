---
import { socialLinks } from "../config/links";

interface Release {
  title: string;
  year: string;
  cover: string;
  spotify: string;
}

interface Props {
  releases?: Release[];
  status?: "live" | "rss" | "scrape" | "fallback" | "error";
}

// Ενημερωμένα Fallbacks με σωστά links (αντικατάστησε τα IDs αν θες)
const fallbackReleases: Release[] = [
  {
    title: "Deciduous EP",
    year: "2024",
    cover: "/images/Mr.%20Bonzo%20half%20face.jpg",
    spotify: "https://open.spotify.com/album/4cOdzhvD7U30vO7nR9p9jY" 
  },
  {
    title: "Rhythms Of Silence",
    year: "2020",
    cover: "/images/Mr.%20Bonzo%20Beats%20in%20the%20studio.jpg",
    spotify: "https://open.spotify.com/album/4cOdzhvD7U30vO7nR9p9jY"
  }
];

const { releases = fallbackReleases, status = "fallback" } = Astro.props;
const spotifyUrl = socialLinks.spotify?.includes("YOUR_ID_HERE")
  ? "https://open.spotify.com/"
  : socialLinks.spotify;

const statusLabel =
  status === "live"
    ? "Spotify API: Live Data"
    : status === "rss"
      ? "RSS Feed: Live Data"
      : status === "scrape"
        ? "Live Data"
      : status === "error"
        ? "Spotify API: Error (Fallback Data)"
        : "Spotify API: Fallback Data";
---

<section id="releases" class="mt-24">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-6 border-b border-fuchsia-500/10 pb-6">
    <div>
      <h3 class="display-heading text-4xl font-black uppercase tracking-tighter text-white sm:text-5xl" data-i18n="releases.title">
        Latest Releases
      </h3>
      {
        status !== "scrape" && (
          <div class="mt-3 flex items-center gap-2">
            <span class={`h-2 w-2 rounded-full ${status === 'live' || status === 'rss' || status === 'scrape' ? 'bg-green-500 animate-pulse' : 'bg-fuchsia-500'}`}></span>
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-fuchsia-300/60" data-i18n-status={status}>
              {statusLabel}
            </p>
          </div>
        )
      }
    </div>
    
    <a
      href={spotifyUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative overflow-hidden rounded-full bg-fuchsia-600 px-8 py-3 text-[11px] font-black uppercase tracking-[0.2em] text-white transition-all hover:bg-fuchsia-500 hover:shadow-[0_0_25px_rgba(217,70,239,0.5)]"
      data-i18n="releases.follow"
    >
      Follow on Spotify
    </a>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      releases.map((release) => (
        <a 
          href={release.spotify} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group relative flex flex-col overflow-hidden rounded-2xl border border-fuchsia-500/10 bg-white/[0.03] transition-all duration-500 hover:-translate-y-1.5 hover:border-fuchsia-500/40 hover:bg-white/[0.06] hover:shadow-[0_16px_30px_rgba(0,0,0,0.35)]"
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img 
              src={release.cover} 
              alt={`${release.title} cover`} 
              loading="lazy" 
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" 
            />
            <div class="absolute inset-0 flex items-center justify-center bg-black/40 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
               <div class="rounded-full bg-white/10 p-3 backdrop-blur-md border border-white/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
               </div>
            </div>
          </div>

          <div class="flex flex-1 flex-col p-4 sm:p-5">
            <h4 class="text-lg sm:text-xl font-black uppercase tracking-tight text-white group-hover:text-fuchsia-400 transition-colors line-clamp-2">
              {release.title}
            </h4>
            <div class="mt-1.5 flex items-center justify-between">
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-fuchsia-300/40">{release.year}</p>
              <span class="text-[9px] font-black uppercase tracking-widest text-fuchsia-500 opacity-0 transition-all group-hover:opacity-100" data-i18n="releases.listenNow">Listen Now →</span>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>