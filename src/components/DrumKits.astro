---
const drumKits = [
  {
    title: "TRIPPY DRUM KIT",
    description: "Elevate your production with 120+ high-quality Trap sounds. Essential kicks, sharp snares, and trippy percussion designed for modern heavy-hitters.",
    price: "FREE",
    // Το αρχείο που μετονομάσαμε και καθαρίσαμε
    image: "/images/Trippy-Drum-kit.webp", 
    link: "https://www.beatstars.com/mrbonzobeats/sound-kits/153315"
  }
];
---

<section id="drumkits" class="mt-32 scroll-mt-36 px-6">
  <div class="flex flex-col items-center mb-16 text-center">
    <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase italic text-white" data-i18n="drumkits.title">
      SOUND <span class="text-fuchsia-500">KITS</span>
    </h2>
    <div class="h-1.5 w-24 bg-fuchsia-600 mt-4 rounded-full shadow-[0_0_20px_rgba(192,38,211,1)]"></div>
  </div>

  <div class="grid grid-cols-1 max-w-4xl mx-auto">
    {drumKits.map((kit) => (
      <div class="group relative overflow-hidden rounded-[2.5rem] border border-white/5 bg-gradient-to-b from-white/10 to-transparent p-8 transition-all duration-500 hover:border-fuchsia-500/50 hover:shadow-[0_0_40px_rgba(192,38,211,0.1)]">
        
        <div class="flex flex-col md:flex-row gap-12 items-center text-center md:text-left">
          
          <div class="relative w-64 h-64 flex-shrink-0 flex items-center justify-center">
             <div class="absolute w-40 h-40 bg-fuchsia-600/20 rounded-full blur-[60px] group-hover:bg-fuchsia-600/40 transition-all duration-500"></div>
             
             <img 
               src={kit.image} 
               alt={kit.title} 
               class="relative w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-110 group-hover:-rotate-3 group-hover:-translate-y-4 drop-shadow-[0_20px_50px_rgba(0,0,0,0.7)]" 
               onerror="this.src='/images/logo-main.webp'; this.style.padding='40px';"
             />
          </div>
          
          <div class="flex-grow">
            <h3 class="text-3xl font-bold text-white mb-4 tracking-tight uppercase italic">
              {kit.title}
            </h3>
            <p class="text-gray-400 text-lg leading-relaxed mb-8 max-w-md" data-i18n="drumkits.description">
              {kit.description}
            </p>
            
            <div class="flex items-center justify-center md:justify-start gap-8">
              <span class="text-4xl font-black text-fuchsia-500 drop-shadow-[0_0_10px_rgba(192,38,211,0.5)] tracking-tighter italic uppercase">
                {kit.price}
              </span>
              
              <a 
                href={kit.link} 
                target="_blank"
                class="inline-flex items-center justify-center rounded-full bg-white px-10 py-4 text-sm font-black uppercase tracking-widest text-black transition-all hover:bg-fuchsia-500 hover:text-white hover:shadow-[0_0_20px_rgba(192,38,211,0.5)] active:scale-95"
                data-i18n="drumkits.getBtn"
              >
                Get Free Kit
              </a>
            </div>
          </div>

        </div>
      </div>
    ))}
  </div>
</section>