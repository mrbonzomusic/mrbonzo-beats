---
const drumKits = [
  {
    title: "TRIPPY DRUM KIT",
    description: "Elevate your production with 120+ high-quality Trap sounds. Essential kicks, sharp snares, and trippy percussion designed for modern heavy-hitters.",
    price: "FREE",
    image: "/images/Trippy-Drum-kit.webp", 
    link: "https://www.beatstars.com/mrbonzobeats/sound-kits/153315"
  }
];
---

<section id="drumkits" class="mt-32 scroll-mt-36 px-6">
  <div class="flex flex-col items-center mb-20 text-center">
    <h2 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic text-white" data-i18n="drumkits.title">
      SOUND <span class="text-fuchsia-500">KITS</span>
    </h2>
    <div class="h-2 w-32 bg-fuchsia-600 mt-6 rounded-full shadow-[0_0_25px_rgba(192,38,211,1)]"></div>
  </div>

  <div class="grid grid-cols-1 max-w-5xl mx-auto">
    {drumKits.map((kit) => (
      <div class="group relative overflow-hidden rounded-[3rem] border border-white/10 bg-gradient-to-b from-white/10 via-white/5 to-transparent p-10 transition-all duration-500 hover:border-fuchsia-500/50 hover:shadow-[0_0_50px_rgba(192,38,211,0.15)]">
        
        <div class="flex flex-col lg:flex-row gap-12 items-center text-center lg:text-left">
          
          <div class="relative w-64 h-64 sm:w-80 sm:h-80 flex-shrink-0 flex items-center justify-center">
             <div class="absolute w-48 h-48 bg-fuchsia-600/20 rounded-full blur-[80px] group-hover:bg-fuchsia-600/40 transition-all duration-500"></div>
             
             <img 
               src={kit.image} 
               alt={kit.title} 
               data-fallback-src="/images/logo-main.webp"
               class="relative w-full h-full object-contain transition-transform duration-700 ease-out group-hover:scale-110 group-hover:-rotate-3 group-hover:-translate-y-4 drop-shadow-[0_30px_60px_rgba(0,0,0,0.8)]" 
             />
          </div>
          
          <div class="flex-grow">
            <h3 class="text-4xl font-black text-white mb-6 tracking-tight uppercase italic sm:text-5xl">
              {kit.title}
            </h3>
            <p class="text-gray-300 text-lg leading-relaxed mb-10 max-w-xl sm:text-xl" data-i18n="drumkits.description">
              {kit.description}
            </p>
            
            <div class="flex flex-wrap items-center justify-center lg:justify-start gap-10">
              <span class="text-5xl font-black text-fuchsia-500 drop-shadow-[0_0_15px_rgba(192,38,211,0.6)] tracking-tighter italic uppercase" data-i18n="drumkits.freeLabel">
                {kit.price}
              </span>
              
              <a 
                href={kit.link} 
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-full bg-white px-12 py-5 text-[15px] font-black uppercase tracking-[0.2em] text-black transition-all hover:bg-fuchsia-500 hover:text-white hover:shadow-[0_0_30px_rgba(192,38,211,0.6)] active:scale-95"
                data-i18n="drumkits.getBtn"
              >
                Get Free Kit
              </a>
            </div>
          </div>

        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.querySelectorAll('img[data-fallback-src]').forEach((img) => {
    img.addEventListener('error', () => {
      const fallbackSrc = img.getAttribute('data-fallback-src');
      if (!fallbackSrc || img.getAttribute('src') === fallbackSrc) return;
      img.setAttribute('src', fallbackSrc);
      img.style.padding = '40px';
    });
  });
</script>