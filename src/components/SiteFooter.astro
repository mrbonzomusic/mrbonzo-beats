---
import { socialLinks } from "../config/links";
---

<footer class="mt-32 pb-16 border-t border-white/5">
  <div class="mx-auto max-w-7xl px-4 pt-16">
    <div class="flex flex-col items-center justify-between gap-12 lg:flex-row lg:items-end">
      
      <div class="text-center lg:text-left">
        <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-white/30">
          © 2026 <span class="text-fuchsia-500">Mr. Bonzo.</span> All rights reserved.
        </p>
      </div>

      <div class="flex flex-col items-center">
        <span class="text-[9px] font-black uppercase tracking-[0.2em] text-fuchsia-500 mb-2">Global Traffic</span>
        <div class="flex items-center gap-3 bg-white/5 border border-white/10 rounded-xl px-4 py-2">
          <div class="flex flex-col items-center border-r border-white/10 pr-3">
            <span id="stats-count" class="text-lg font-mono font-bold text-white leading-none">0000</span>
            <span class="text-[7px] uppercase tracking-tighter text-white/40 mt-1">Total Hits</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 bg-fuchsia-500 rounded-full animate-pulse"></div>
            <span class="text-[10px] font-bold uppercase tracking-widest text-white/80">Active</span>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap justify-center gap-6">
        <a href={socialLinks.instagram} target="_blank" class="text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-fuchsia-400 transition">Instagram</a>
        <a href="https://www.youtube.com/@mrbonzobeatz" target="_blank" class="text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-fuchsia-400 transition">YouTube</a>
        <a href="mailto:mrbonzomusic@gmail.com" class="text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-fuchsia-400 transition">Email</a>
        <a href={socialLinks.tiktok} target="_blank" class="text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-fuchsia-400 transition">TikTok</a>
        <a href={socialLinks.spotify} target="_blank" class="text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-fuchsia-400 transition">Spotify</a>
      </div>

    </div>
  </div>
</footer>

<script is:inline>
  async function syncGoatStats() {
    const el = document.getElementById('stats-count');
    if (!el) return;

    try {
      // Τραβάμε τα δεδομένα από το GoatCounter API
      const response = await fetch('https://mrbonzo.goatcounter.com/counter/total.json', {
        method: 'GET',
        cache: 'no-cache'
      });

      const data = await response.json();

      if (data && typeof data.count !== 'undefined') {
        // Καθαρίζουμε το νούμερο και το κάνουμε format 0000
        const rawCount = data.count.toString().replace(/[^0-9]/g, '');
        el.innerText = rawCount.padStart(4, '0');
        console.log("Stats Synced:", rawCount);
      }
    } catch (err) {
      console.log("Stats update pending...");
    }
  }

  // Εκτέλεση αμέσως
  syncGoatStats();

  // Ανανέωση κάθε 15 δευτερόλεπτα
  setInterval(syncGoatStats, 15000);
</script>