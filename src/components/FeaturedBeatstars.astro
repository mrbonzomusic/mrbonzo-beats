      src={beatstarsLinks.player}
      width="100%"
      height="300" 
      title="Mr. Bonzo Beatstars Player"
      style="border:none; border-radius: 20px;"
      loading="lazy"
    >
      -- none --
    </iframe>
  </div>
</section>