---
import { beatstarsLinks } from "../config/links";

const playerUrl = "https://www.beatstars.com/player/?storeId=133234";
---

<section id="player" class="scroll-mt-20 px-2 sm:px-4">
  <div class="relative mx-auto max-w-[95%] lg:max-w-7xl group">
    <div class="absolute -inset-0.5 bg-gradient-to-r from-fuchsia-600/10 to-purple-600/10 rounded-[2rem] blur opacity-75 group-hover:opacity-100 transition duration-1000"></div>
    
    <div class="relative overflow-hidden rounded-[2rem] border border-white/5 bg-black p-0.5 shadow-2xl">
      <iframe
        src={playerUrl}
        width="100%"
        title="Mr. Bonzo Beatstars Player"
        style="height: calc(100dvh - 140px); min-height: 550px; border:none; border-radius: 30px;"
        loading="lazy"
        class="bg-black w-full"
        allow="autoplay"
      >
        -- Your browser does not support iframes --
      </iframe>
    </div>
  </div>

  <p class="mt-3 text-center text-[9px] tracking-[0.2em] text-white/10 uppercase font-medium">
    Secure Checkout • Licensing & Contracts powered by Beatstars
  </p>
</section>