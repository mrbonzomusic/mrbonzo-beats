---
import { beatstarsLinks } from "../config/links";
---

<section id="player" class="mt-24 scroll-mt-36">
  <div class="relative mx-auto max-w-5xl group">
    <div class="absolute -inset-1 bg-gradient-to-r from-fuchsia-600/20 to-purple-600/20 rounded-[2.5rem] blur opacity-75 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
    
    <div class="relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-black p-1 shadow-2xl">
      <iframe
        src={beatstarsLinks.player}
        width="100%"
        height="550" 
        title="Mr. Bonzo Beatstars Player"
        style="border:none; border-radius: 32px;"
        loading="lazy"
        class="bg-black"
      >
        -- Your browser does not support iframes --
      </iframe>
    </div>
  </div>

  <p class="mt-6 text-center text-xs tracking-[0.2em] text-white/20 uppercase font-medium">
    Secure Checkout powered by Beatstars
  </p>
</section>