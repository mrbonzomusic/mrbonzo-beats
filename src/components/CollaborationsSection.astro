---
import { collaborators } from "../config/collaborations";

const safeCollaborators = collaborators || [];
const marquee = [...safeCollaborators, ...safeCollaborators];
---

<section id="collaborations" class="section-reveal relative mt-8 overflow-hidden rounded-3xl border border-fuchsia-500/30 bg-black/80 px-6 py-6 sm:px-10 sm:py-8">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_0%_50%,rgba(168,85,247,0.14),transparent_35%),radial-gradient(circle_at_100%_50%,rgba(217,70,239,0.12),transparent_35%)]"></div>
  
  <div class="relative">
    <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
      <h3 class="text-xl font-black uppercase tracking-tight text-white sm:text-2xl" data-i18n="collaborations.title">
        Collaborations
      </h3>

      <div class="marquee-track w-full md:max-w-[70%]">
        <div class="marquee-content">
          {
            marquee.length > 0 ? (
              marquee.map((artist, idx) => (
                <span class="inline-flex items-center text-sm font-extrabold uppercase tracking-[0.2em] text-fuchsia-200 sm:text-base">
                  {artist}
                  <span class="mx-6 text-fuchsia-500/60 drop-shadow-[0_0_8px_rgba(217,70,239,0.5)]">✦</span>
                </span>
              ))
            ) : (
              <span class="text-fuchsia-200/50" data-i18n="collaborations.comingSoon">Coming Soon...</span>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-content {
    display: inline-flex;
    white-space: nowrap;
    animation: brand-ticker 35s linear infinite;
  }

  @keyframes brand-ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee-track:hover .marquee-content {
    animation-play-state: paused;
  }
</style>