---
const logoPath = "/images/logo-main.webp";

// Links
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const spotifyLink = "https://open.spotify.com/artist/4Xm35NqLpxfL759C8YAnC6"; // Το Spotify Link σου
---

<section class="relative overflow-hidden rounded-3xl border border-fuchsia-500/40 bg-black px-6 py-8 shadow-xl shadow-fuchsia-900/20 sm:px-12 sm:py-12">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(217,70,239,0.2),_transparent_50%)]"></div>

  <div class="relative flex flex-col items-center text-center">
    <p class="mb-3 text-[9px] font-bold uppercase tracking-[0.4em] text-fuchsia-400/60" data-i18n="hero.label">
      Beatmaker Portfolio
    </p>
    
    <div class="relative group">
      <div class="absolute inset-0 scale-100 bg-fuchsia-500/15 blur-2xl rounded-full"></div>
      <img 
        src={logoPath} 
        alt="Mr. Bonzo" 
        class="relative h-auto w-[180px] drop-shadow-[0_0_20px_rgba(217,70,239,0.3)] sm:w-[300px] lg:w-[380px] animate-fade-in"
      />
    </div>

    <p class="mt-4 max-w-xl text-sm leading-relaxed text-purple-100/60 sm:text-base" data-i18n="hero.subtitle">
      Dark, modern, and aggressive type beats built for artists who want energy and edge.
    </p>

    <div class="mt-8 flex flex-wrap justify-center items-center gap-3">
      
      <a
        href="#beats"
        class="group relative overflow-hidden rounded-full bg-white/5 border border-fuchsia-500/30 px-6 py-2.5 text-[11px] font-black uppercase tracking-widest text-fuchsia-100 backdrop-blur-sm transition-all hover:bg-fuchsia-500/10 hover:border-fuchsia-400 active:scale-95"
      >
        <span class="relative z-10" data-i18n="hero.browse">Browse Beats</span>
      </a>
      
      <a
        href="#beatstars"
        class="group relative overflow-hidden rounded-full bg-fuchsia-600 px-6 py-2.5 text-[11px] font-black uppercase tracking-widest text-white transition-all hover:scale-105 hover:bg-fuchsia-500 active:scale-95 shadow-[0_0_20px_rgba(217,70,239,0.4)]"
      >
        <span class="relative z-10">Featured Player</span>
        <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-transform duration-500 group-hover:translate-x-full"></div>
      </a>

      <div class="relative inline-block text-left" id="yt-dropdown-container">
        <button
          id="yt-dropdown-btn"
          class="flex items-center gap-2 rounded-full bg-red-600/10 border border-red-600/30 px-6 py-2.5 text-[11px] font-black uppercase tracking-widest text-red-500 transition-all hover:bg-red-600/20 active:scale-95"
        >
          YouTube
          <svg id="yt-arrow" class="h-3 w-3 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
        </button>

        <div 
          id="yt-menu" 
          class="invisible opacity-0 absolute top-full left-1/2 -translate-x-1/2 mt-2 w-48 rounded-xl border border-white/10 bg-zinc-950 p-1 shadow-2xl transition-all duration-200 z-"
        >
          <a href={ytArtist} target="_blank" class="block rounded-lg px-4 py-2 text-left text-[10px] font-bold uppercase tracking-tight text-white hover:bg-red-600/20 hover:text-red-400">
            Official Artist
          </a>
          <a href={ytBeats} target="_blank" class="block rounded-lg px-4 py-2 text-left text-[10px] font-bold uppercase tracking-tight text-white hover:bg-red-600/20 hover:text-red-400 border-t border-white/5">
            Beats Channel
          </a>
        </div>
      </div>

      <a 
        href={pond5Link} 
        target="_blank" 
        class="flex items-center gap-2 rounded-full bg-orange-600/10 border border-orange-600/30 px-6 py-2.5 text-[11px] font-black uppercase tracking-widest text-orange-500 transition-all hover:bg-orange-600/20 active:scale-95"
      >
        Pond5
      </a>

      <a 
        href={spotifyLink} 
        target="_blank" 
        class="rounded-full bg-green-600/10 border border-green-600/30 p-2.5 text-green-500 transition-all hover:bg-green-600/20 hover:scale-110 active:scale-95"
        title="Spotify"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.508 17.302c-.223.367-.703.483-1.07.259-2.822-1.725-6.375-2.115-10.559-1.161-.422.096-.843-.164-.939-.585-.097-.421.163-.842.585-.939 4.577-1.045 8.5-1.59 11.685.353.367.224.483.704.258 1.072zm1.47-3.253c-.28.455-.878.604-1.332.324-3.23-1.985-8.155-2.558-11.975-1.398-.513.156-1.05-.145-1.206-.658-.156-.513.145-1.05.658-1.206 4.37-1.326 9.81-.685 13.53 1.601.454.28.604.877.324 1.331zm.126-3.37c-3.873-2.3-10.274-2.513-13.998-1.383-.594.18-1.229-.162-1.41-.756-.18-.594.162-1.23.756-1.41 4.27-1.297 11.336-1.043 15.795 1.604.535.318.71.1 1.012.634.318.535.14 1.21-.395 1.528z"/></svg>
      </a>

    </div>
  </div>
</section>

<script is:inline>
  // Dropdown Logic
  const btn = document.getElementById('yt-dropdown-btn');
  const menu = document.getElementById('yt-menu');
  const arrow = document.getElementById('yt-arrow');

  if (btn && menu && arrow) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = menu.classList.contains('opacity-100');
      
      if (isOpen) {
        menu.classList.add('invisible', 'opacity-0');
        menu.classList.remove('opacity-100');
        arrow.classList.remove('rotate-180');
      } else {
        menu.classList.remove('invisible', 'opacity-0');
        menu.classList.add('opacity-100');
        arrow.classList.add('rotate-180');
      }
    });

    // Close on outside click
    document.addEventListener('click', () => {
      menu.classList.add('invisible', 'opacity-0');
      menu.classList.remove('opacity-100');
      arrow.classList.remove('rotate-180');
    });
  }
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  html {
    scroll-behavior: smooth;
  }
</style>