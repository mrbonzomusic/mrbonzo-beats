---
import { aboutContent } from "../config/about";
import { socialLinks } from "../config/links";

const licenses = [
  {
    name: "Basic Lease",
    price: "$29.99",
    features: ["MP3 File", "5,000 Copies", "200k Streams", "Non-Exclusive"]
  },
  {
    name: "Premium Lease",
    price: "$49.99",
    features: ["WAV + MP3", "10k Copies", "500k Streams", "Non-Exclusive"]
  },
  {
    name: "Exclusive License",
    price: "$150.00+",
    features: ["Full Ownership", "Trackouts + WAV", "Unlimited", "Exclusive"]
  }
];

const tags = ["Beatmaker", "Engineer", "Producer"];
---

<section id="about" class="relative mt-12 lg:mt-24 overflow-hidden rounded-[2rem] lg:rounded-[2.5rem] border border-fuchsia-500/20 bg-black shadow-2xl mx-2 sm:mx-4">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_20%,rgba(168,85,247,0.08),transparent_40%)]"></div>

  <div class="relative grid items-stretch lg:grid-cols-[1fr_1.2fr]">
    
    <div class="relative h-[250px] sm:h-[350px] lg:h-full overflow-hidden">
      <img
        src="/images/Mr-Bonzo-half-face.webp"
        alt="Mr. Bonzo Portrait"
        class="h-full w-full object-cover object-top lg:object-center transition duration-700 hover:scale-105"
      />
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black via-black/60 to-transparent lg:hidden"></div>
    </div>

    <div class="relative flex flex-col justify-between px-5 py-8 sm:px-12 lg:px-16 lg:py-16">
      
      <div class="relative min-h-[420px] sm:min-h-[450px] lg:min-h-[400px] flex items-center">
        
        <div id="slide-0" class="slide w-full transition-all duration-500 ease-out opacity-100 translate-x-0 relative">
          <p class="text-[9px] lg:text-[10px] font-black uppercase tracking-[0.3em] text-fuchsia-400">The Artist</p>
          <h2 class="mt-2 text-2xl font-black uppercase leading-tight text-white sm:text-4xl lg:text-5xl">The Architect <br class="hidden sm:block"/><span class="text-fuchsia-500 text-xl sm:text-4xl lg:text-5xl">of Energy</span></h2>
          <p class="mt-4 lg:mt-6 text-[13px] leading-relaxed text-gray-400 sm:text-base max-w-prose">{aboutContent.en.bio}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full border border-fuchsia-500/20 bg-fuchsia-500/5 px-3 py-1 text-[8px] lg:text-[9px] font-black text-fuchsia-300 uppercase tracking-widest">{tag}</span>
            ))}
          </div>
        </div>

        <div id="slide-1" class="slide absolute inset-0 w-full transition-all duration-500 ease-out opacity-0 translate-x-12 pointer-events-none flex flex-col justify-center">
          <p class="text-[9px] font-black uppercase tracking-[0.3em] text-fuchsia-400">Terms</p>
          <h2 class="mt-2 text-2xl font-black uppercase text-white sm:text-4xl">Licensing Guide</h2>
          <div class="mt-5 space-y-2.5">
            {licenses.map((l) => (
              <div class="group rounded-xl lg:rounded-2xl border border-white/5 bg-white/[0.02] p-3 lg:p-4 transition hover:border-fuchsia-500/30">
                <div class="flex justify-between items-center mb-1">
                  <span class="font-black text-fuchsia-200 text-[10px] lg:text-xs uppercase tracking-wider">{l.name}</span>
                  <span class="text-[9px] lg:text-[10px] font-black text-white bg-fuchsia-600 px-2.5 py-0.5 rounded-full">{l.price}</span>
                </div>
                <p class="text-[9px] lg:text-[10px] text-gray-500 group-hover:text-gray-400 transition tracking-wide">{l.features.join(" • ")}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="slide-2" class="slide absolute inset-0 w-full transition-all duration-500 ease-out opacity-0 translate-x-12 pointer-events-none flex flex-col justify-center text-left">
          <p class="text-[9px] font-black uppercase tracking-[0.3em] text-green-400">Claims</p>
          <h2 class="mt-2 text-2xl font-black uppercase text-white sm:text-4xl">Usage Policy</h2>
          <div class="mt-5 space-y-3 lg:space-y-4">
            <div class="rounded-xl border border-green-500/20 bg-green-500/5 p-4 lg:p-5">
              <span class="text-[10px] lg:text-[11px] font-black text-green-400 uppercase block mb-1 tracking-widest">Free Beats (Non-Profit)</span>
              <p class="text-[11px] lg:text-sm text-gray-400 leading-relaxed italic">Evaluate for free. Credit is mandatory (Prod. by Mr. Bonzo). For whitelisting, contact me.</p>
            </div>
            <div class="rounded-xl border border-fuchsia-500/20 bg-fuchsia-500/5 p-4 lg:p-5">
              <span class="text-[10px] lg:text-[11px] font-black text-fuchsia-400 uppercase block mb-1 tracking-widest">Paid Licenses (Claims)</span>
              <p class="text-[11px] lg:text-sm text-gray-400 leading-relaxed italic">Purchased? Send YT link + receipt. Claims cleared within 24h.</p>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-8 lg:mt-12 flex flex-col items-center gap-6 sm:flex-row sm:justify-between border-t border-white/5 pt-6 lg:pt-8">
        <div class="flex items-center gap-4">
          <button id="prevBtn" class="p-2.5 border border-fuchsia-500/20 rounded-full hover:bg-fuchsia-500/10 active:scale-90 transition-all">
            <svg class="w-4 h-4 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 19l-7-7 7-7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          
          <div class="flex gap-2">
            <div id="dot-0" class="dot h-1 w-6 lg:w-8 bg-fuchsia-500 rounded-full transition-all duration-300"></div>
            <div id="dot-1" class="dot h-1 w-1.5 lg:w-2 bg-fuchsia-500/20 rounded-full transition-all duration-300"></div>
            <div id="dot-2" class="dot h-1 w-1.5 lg:w-2 bg-fuchsia-500/20 rounded-full transition-all duration-300"></div>
          </div>

          <button id="nextBtn" class="p-2.5 border border-fuchsia-500/20 rounded-full hover:bg-fuchsia-500/10 active:scale-90 transition-all">
            <svg class="w-4 h-4 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>

        <a href={socialLinks.instagram} target="_blank" class="w-full sm:w-auto text-center rounded-full bg-fuchsia-600 px-6 lg:px-8 py-3 lg:py-4 text-[10px] lg:text-[11px] font-black uppercase tracking-[0.2em] text-white hover:bg-fuchsia-500 transition-all shadow-lg shadow-fuchsia-600/20">
          Contact for Customs
        </a>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  (function() {
    let current = 0;
    const slides = [document.getElementById('slide-0'), document.getElementById('slide-1'), document.getElementById('slide-2')];
    const dots = [document.getElementById('dot-0'), document.getElementById('dot-1'), document.getElementById('dot-2')];
    
    function showSlide(index) {
      slides.forEach((s, i) => {
        if (!s || !dots[i]) return;
        const isActive = i === index;
        s.classList.toggle('opacity-100', isActive);
        s.classList.toggle('relative', isActive);
        s.classList.toggle('translate-x-0', isActive);
        s.classList.toggle('opacity-0', !isActive);
        s.classList.toggle('absolute', !isActive);
        s.classList.toggle('pointer-events-none', !isActive);
        s.style.transform = isActive ? 'translateX(0)' : (i > index ? 'translateX(20px)' : 'translateX(-20px)');
        
        // Dots animation για κινητά
        const activeWidth = window.innerWidth < 1024 ? 'w-6' : 'w-8';
        const inactiveWidth = window.innerWidth < 1024 ? 'w-1.5' : 'w-2';
        
        dots[i].className = `dot h-1 transition-all duration-300 rounded-full ${isActive ? activeWidth + ' bg-fuchsia-500' : inactiveWidth + ' bg-fuchsia-500/20'}`;
      });
      current = index;
    }
    document.getElementById('nextBtn')?.addEventListener('click', () => showSlide((current + 1) % 3));
    document.getElementById('prevBtn')?.addEventListener('click', () => showSlide((current + 2) % 3));
  })();
</script>