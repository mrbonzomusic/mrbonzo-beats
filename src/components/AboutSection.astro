---
import { aboutContent } from "../config/about";
import { socialLinks } from "../config/links";

// Ενημερωμένα Licenses με βάση τα screenshots σου
const licenses = [
  {
    name: "Basic Lease",
    price: "$29.99",
    features: [
      "MP3 File", 
      "5,000 Distribution Copies", 
      "200,000 Audio Streams", 
      "50% Writer Publishing Share",
      "Non-Profit Performances Only"
    ]
  },
  {
    name: "Premium Lease",
    price: "$49.99",
    features: [
      "WAV + MP3", 
      "10,000 Distribution Copies", 
      "500,000 Audio Streams", 
      "5 Radio Stations Allowed",
      "Up to 10 For-Profit Performances",
      "50% Writer Publishing Share"
    ]
  },
  {
    name: "Unlimited License",
    price: "$199.99",
    features: [
      "Trackouts + WAV + MP3", 
      "Unlimited Distribution & Streams", 
      "Unlimited Radio Rights",
      "Unlimited For-Profit Performances",
      "50% Writer Publishing Share"
    ]
  }
];
---

<section id="about" class="relative mt-16 overflow-hidden rounded-3xl border border-fuchsia-500/30 bg-black">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_20%,rgba(168,85,247,0.18),transparent_40%),radial-gradient(circle_at_80%_70%,rgba(217,70,239,0.14),transparent_45%)]"></div>

  <div class="relative grid items-stretch gap-0 lg:grid-cols-[1fr_1.2fr]">
    
    <div class="relative min-h-[320px] lg:min-h-[550px]">
      <img
        src="/images/Mr-Bonzo-half-face.webp"
        alt="Mr. Bonzo portrait"
        class="h-full w-full object-cover object-center"
        loading="lazy"
      />
      <div class="pointer-events-none absolute inset-y-0 right-0 hidden w-28 bg-gradient-to-r from-transparent to-black lg:block"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-b from-transparent to-black lg:hidden"></div>
    </div>

    <div class="relative flex flex-col justify-center px-6 py-12 text-center sm:px-10 lg:px-16 lg:text-left">
      
      <div class="relative overflow-hidden min-h-[400px] sm:min-h-[350px]">
        
        <div id="slide-bio" class="transition-all duration-500 transform opacity-100 translate-x-0">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-fuchsia-300/85" data-i18n="about.label">The Artist</p>
          <h2 class="mt-3 text-3xl font-black uppercase tracking-tight text-white sm:text-4xl lg:text-5xl">
            <span data-i18n="about.title">The Architect of Energy</span>
          </h2>
          <p class="mt-5 text-sm leading-relaxed text-purple-100/85 sm:text-base" data-i18n="about.bio">
            {aboutContent.en.bio}
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full border border-fuchsia-500/40 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-fuchsia-200">Beatmaker</span>
            <span class="rounded-full border border-fuchsia-500/40 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-fuchsia-200">Engineer</span>
            <span class="rounded-full border border-fuchsia-500/40 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-fuchsia-200">Producer</span>
          </div>
        </div>

        <div id="slide-licenses" class="absolute top-0 left-0 w-full transition-all duration-500 transform opacity-0 translate-x-full pointer-events-none">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-fuchsia-300/85">Terms & Usage</p>
          <h2 class="mt-3 text-3xl font-black uppercase tracking-tight text-white sm:text-4xl">Licensing Guide</h2>
          
          <div class="mt-6 space-y-3">
            {licenses.map((license) => (
              <div class="rounded-xl border border-white/5 bg-white/5 p-4 text-left transition hover:border-fuchsia-500/40 group">
                <div class="flex justify-between items-center mb-1.5">
                  <h3 class="font-black uppercase text-fuchsia-300 text-xs sm:text-sm tracking-wide group-hover:text-fuchsia-400 transition-colors">{license.name}</h3>
                  <span class="text-[10px] font-black text-white bg-fuchsia-500/20 px-2 py-0.5 rounded-md border border-fuchsia-500/30">{license.price}</span>
                </div>
                <p class="text-[10px] sm:text-[11px] text-purple-100/60 leading-relaxed italic">
                  {license.features.join(" • ")}
                </p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-8">
        <div class="flex items-center gap-5 order-2 sm:order-1">
          <button id="prevBtn" class="group rounded-full border border-fuchsia-500/30 p-3 transition hover:bg-fuchsia-500/20 active:scale-90">
            <svg class="h-4 w-4 stroke-fuchsia-300 transition group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          
          <div class="flex gap-2.5">
            <div id="dot-0" class="h-1.5 w-8 rounded-full bg-fuchsia-500 transition-all duration-300"></div>
            <div id="dot-1" class="h-1.5 w-2 rounded-full bg-fuchsia-500/20 transition-all duration-300"></div>
          </div>

          <button id="nextBtn" class="group rounded-full border border-fuchsia-500/30 p-3 transition hover:bg-fuchsia-500/20 active:scale-90">
            <svg class="h-4 w-4 stroke-fuchsia-300 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>

        <a
          href={socialLinks.instagram}
          target="_blank"
          class="order-1 sm:order-2 inline-flex items-center justify-center rounded-full bg-fuchsia-600 px-10 py-3.5 text-[10px] font-black uppercase tracking-[0.25em] text-white shadow-[0_0_30px_rgba(217,70,239,0.3)] transition hover:bg-fuchsia-500 hover:scale-105 active:scale-95"
        >
          Contact for Customs
        </a>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  let currentSlide = 0;
  const slides = [
    document.getElementById('slide-bio'),
    document.getElementById('slide-licenses')
  ];
  const dots = [
    document.getElementById('dot-0'),
    document.getElementById('dot-1')
  ];

  function updateSlider(index) {
    slides.forEach((slide, i) => {
      if (i === index) {
        // Show Active Slide
        slide.classList.remove('opacity-0', 'translate-x-full', '-translate-x-full', 'pointer-events-none', 'absolute');
        slide.classList.add('opacity-100', 'translate-x-0', 'relative');
        // Update Dots
        dots[i].classList.remove('w-2', 'bg-fuchsia-500/20');
        dots[i].classList.add('w-8', 'bg-fuchsia-500');
      } else {
        // Hide Inactive Slide
        slide.classList.add('opacity-0', 'pointer-events-none', 'absolute');
        slide.classList.remove('opacity-100', 'translate-x-0', 'relative');
        // Update Dots
        dots[i].classList.add('w-2', 'bg-fuchsia-500/20');
        dots[i].classList.remove('w-8', 'bg-fuchsia-500');
        
        // Push to left or right based on position
        if (i < index) slide.classList.add('-translate-x-full');
        else slide.classList.add('translate-x-full');
      }
    });
    currentSlide = index;
  }

  document.getElementById('nextBtn').addEventListener('click', () => {
    updateSlider((currentSlide + 1) % slides.length);
  });

  document.getElementById('prevBtn').addEventListener('click', () => {
    updateSlider((currentSlide - 1 + slides.length) % slides.length);
  });
</script>