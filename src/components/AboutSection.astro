---
import { aboutContent } from "../config/about";
import { socialLinks } from "../config/links";

const licenses = [
  {
    name: "Basic Lease",
    price: "$29.99",
    features: ["MP3 File", "5,000 Copies", "200k Streams", "50% Writer Share"]
  },
  {
    name: "Premium Lease",
    price: "$49.99",
    features: ["WAV + MP3", "10k Copies", "500k Streams", "50% Writer Share"]
  },
  {
    name: "Exclusive License",
    price: "$150.00",
    features: ["Full Ownership", "Trackouts + WAV", "Unlimited Everything"]
  }
];
---

<section id="about" class="relative mt-12 overflow-hidden rounded-3xl border border-fuchsia-500/30 bg-black">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_20%,rgba(168,85,247,0.15),transparent_40%)]"></div>

  <div class="relative grid items-stretch lg:grid-cols-[1fr_1.2fr]">
    
    <div class="relative min-h-[250px] sm:min-h-[350px] lg:min-h-[600px]">
      <img
        src="/images/Mr-Bonzo-half-face.webp"
        alt="Portrait"
        class="h-full w-full object-cover object-top lg:object-center"
      />
      <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-b from-transparent to-black lg:hidden"></div>
    </div>

    <div class="relative flex flex-col justify-between px-5 py-6 sm:px-10 lg:px-16 lg:py-12 text-center lg:text-left">
      
      <div class="relative overflow-hidden min-h-[320px] sm:min-h-[380px] flex items-center">
        
        <div id="slide-0" class="slide transition-all duration-500 opacity-100 relative w-full">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-fuchsia-300/80">The Artist</p>
          <h2 class="mt-2 text-xl font-black uppercase text-white sm:text-3xl lg:text-5xl">The Architect of Energy</h2>
          <p class="mt-4 text-[13px] leading-relaxed text-gray-300 sm:text-base">{aboutContent.en.bio}</p>
          <div class="mt-5 flex flex-wrap justify-center gap-2 lg:justify-start">
            {["Beatmaker", "Engineer", "Producer"].map(tag => (
              <span class="rounded-full border border-fuchsia-500/30 px-3 py-1 text-[8px] font-bold text-fuchsia-200 uppercase">{tag}</span>
            ))}
          </div>
        </div>

        <div id="slide-1" class="slide absolute top-0 left-0 w-full transition-all duration-500 opacity-0 translate-x-full pointer-events-none">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-fuchsia-300/80">Terms</p>
          <h2 class="mt-2 text-xl font-black uppercase text-white sm:text-3xl">Licensing Guide</h2>
          <div class="mt-5 space-y-2.5">
            {licenses.map(l => (
              <div class="rounded-xl border border-white/5 bg-white/5 p-3 text-left">
                <div class="flex justify-between items-center mb-1">
                  <span class="font-bold text-fuchsia-300 text-[10px] uppercase">{l.name}</span>
                  <span class="text-[9px] font-black text-white bg-fuchsia-500/20 px-2 py-0.5 rounded border border-fuchsia-500/30">{l.price}</span>
                </div>
                <p class="text-[9px] text-gray-400 italic">{l.features.join(" • ")}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="slide-2" class="slide absolute top-0 left-0 w-full transition-all duration-500 opacity-0 translate-x-full pointer-events-none text-left">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-green-400">Claims</p>
          <h2 class="mt-2 text-xl font-black uppercase text-white text-center lg:text-left">Usage Policy</h2>
          <div class="mt-5 space-y-3">
            <div class="rounded-xl border border-green-500/20 bg-green-500/5 p-3">
              <span class="text-[10px] font-bold text-green-400 uppercase block mb-1">Free Beats</span>
              <p class="text-[10px] text-gray-300 leading-relaxed italic">Free for profit with credit. Claims? Contact for whitelisting.</p>
            </div>
            <div class="rounded-xl border border-fuchsia-500/20 bg-fuchsia-500/5 p-3">
              <span class="text-[10px] font-bold text-fuchsia-400 uppercase block mb-1">Paid Licenses</span>
              <p class="text-[10px] text-gray-300 leading-relaxed italic">Send YT link + Receipt. Claims cleared in 24h.</p>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-8 flex flex-col items-center gap-5 sm:flex-row sm:justify-between">
        <a href={socialLinks.instagram} target="_blank" class="order-1 sm:order-2 w-full sm:w-auto rounded-full bg-fuchsia-600 px-6 py-3 text-[10px] font-bold uppercase tracking-[0.2em] text-white transition hover:bg-fuchsia-500">Contact for Customs</a>
        
        <div class="flex items-center gap-3 order-2 sm:order-1">
          <button id="prevBtn" class="p-2 border border-fuchsia-500/30 rounded-full hover:bg-fuchsia-500/20 active:scale-90 transition">
            <svg class="w-4 h-4 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 19l-7-7 7-7" stroke-width="2.5"/></svg>
          </button>
          <div class="flex gap-1.5">
            {.map(i => <div id={`dot-${i}`} class={`dot h-1 ${i===0?'w-5 bg-fuchsia-500':'w-1 bg-fuchsia-500/20'} rounded-full transition-all duration-300`}></div>)}
          </div>
          <button id="nextBtn" class="p-2 border border-fuchsia-500/30 rounded-full hover:bg-fuchsia-500/20 active:scale-90 transition">
            <svg class="w-4 h-4 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" stroke-width="2.5"/></svg>
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  let current = 0;
  const slides = [document.getElementById('slide-0'), document.getElementById('slide-1'), document.getElementById('slide-2')];
  const dots = [document.getElementById('dot-0'), document.getElementById('dot-1'), document.getElementById('dot-2')];
  function showSlide(index) {
    slides.forEach((s, i) => {
      s.classList.toggle('opacity-100', i === index);
      s.classList.toggle('relative', i === index);
      s.classList.toggle('opacity-0', i !== index);
      s.classList.toggle('absolute', i !== index);
      s.classList.toggle('pointer-events-none', i !== index);
      dots[i].classList.toggle('w-5', i === index);
      dots[i].classList.toggle('bg-fuchsia-500', i === index);
      dots[i].classList.toggle('w-1', i !== index);
      dots[i].classList.toggle('bg-fuchsia-500/20', i !== index);
    });
    current = index;
  }
  document.getElementById('nextBtn').addEventListener('click', () => showSlide((current + 1) % 3));
  document.getElementById('prevBtn').addEventListener('click', () => showSlide((current + 2) % 3));
</script>