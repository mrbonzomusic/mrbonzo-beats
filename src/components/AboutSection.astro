---
import { socialLinks } from "../config/links";

const licenses = [
  {
    name: "Basic Lease",
    price: "$29.99",
    features: ["MP3 File", "5,000 Copies", "200k Streams", "Non-Exclusive"]
  },
  {
    name: "Premium Lease",
    price: "$49.99",
    features: ["WAV + MP3", "10k Copies", "500k Streams", "Non-Exclusive"]
  },
  {
    name: "Exclusive License",
    price: "$150.00+",
    features: ["Full Ownership", "Trackouts + WAV", "Unlimited", "Exclusive"]
  }
];

const tags = [
  { key: "about.tagBeatmaker", label: "Beatmaker" },
  { key: "about.tagEngineer", label: "Engineer" },
  { key: "about.tagProducer", label: "Producer" }
];
---

<section id="about" class="relative mt-12 lg:mt-24 overflow-hidden rounded-[2rem] lg:rounded-[2.5rem] border border-fuchsia-500/20 bg-black shadow-2xl mx-2 sm:mx-4">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_20%,rgba(168,85,247,0.08),transparent_40%)]"></div>

  <div class="relative grid items-stretch lg:grid-cols-[1fr_1.2fr]">
    
    <div class="relative h-[300px] sm:h-[450px] lg:h-full overflow-hidden">
      <img
        src="/images/Mr-Bonzo-half-face.webp"
        alt="Mr. Bonzo Portrait"
        data-i18n-alt="ui.aboutPortraitAlt"
        class="h-full w-full object-cover object-top lg:object-center"
      />
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-black via-black/60 to-transparent lg:hidden"></div>
    </div>

    <div class="relative flex flex-col justify-between px-6 py-10 sm:px-12 lg:px-16 lg:py-20">
      
      <div class="relative min-h-[500px] flex items-start lg:items-center">
        
        <div id="slide-0" class="slide w-full transition-all duration-500 opacity-100 translate-x-0 relative text-left">
          <p class="eyebrow-hero-label" data-i18n="about.artistEyebrow">The Artist</p>
          <h2 class="mt-3 text-3xl font-black uppercase leading-tight text-white sm:text-5xl" data-i18n="about.titleHtml">The Architect <br class="hidden sm:block"/><span class="text-fuchsia-500">of Energy</span></h2>
          <p class="mt-6 text-base leading-relaxed text-gray-300 sm:text-lg lg:text-xl" data-i18n="about.bio">
            Alexandros Pilatos is a music producer/audio engineer in Athens, active since 2003. Founder of Purple Sound Studio (2007). His signature sound blends Boom Bap, Lofi, Trap, Dnb, Reggae, Breakbeat, Electronica, and Progressive House.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {tags.map((tag) => (
              <span class="rounded-full border border-fuchsia-500/30 bg-fuchsia-500/10 px-4 py-1.5 text-[10px] font-black text-fuchsia-300 uppercase tracking-wider" data-i18n={tag.key}>{tag.label}</span>
            ))}
          </div>
        </div>

        <div id="slide-1" class="slide absolute inset-0 w-full transition-all duration-500 opacity-0 pointer-events-none flex flex-col justify-center text-left">
          <p class="text-[11px] font-black uppercase tracking-[0.3em] text-fuchsia-400" data-i18n="about.termsLabel">Terms</p>
          <h2 class="mt-3 text-3xl font-black uppercase text-white sm:text-5xl" data-i18n="about.licensingTitle">Licensing Guide</h2>
          <div class="mt-8 space-y-4 w-full">
            {licenses.map((l, idx) => (
              <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5 transition-colors">
                <div class="flex justify-between items-center mb-2">
                  <span class="font-black text-fuchsia-200 text-xs uppercase tracking-widest" data-i18n={idx === 0 ? "about.basicLeaseName" : idx === 1 ? "about.premiumLeaseName" : "about.exclusiveLeaseName"}>{l.name}</span>
                  <span class="text-[11px] font-black text-white bg-fuchsia-600 px-3 py-1 rounded-full">{l.price}</span>
                </div>
                <p class="text-[13px] text-gray-400 tracking-wide" data-i18n={idx === 0 ? "about.basicLeaseFeatures" : idx === 1 ? "about.premiumLeaseFeatures" : "about.exclusiveLeaseFeatures"}>{l.features.join(" • ")}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="slide-2" class="slide absolute inset-0 w-full transition-all duration-500 opacity-0 pointer-events-none flex flex-col justify-center text-left">
          <p class="text-[11px] font-black uppercase tracking-[0.3em] text-green-400" data-i18n="about.policyLabel">Claims</p>
          <h2 class="mt-3 text-3xl font-black uppercase text-white sm:text-5xl" data-i18n="about.policyTitle">Usage Policy</h2>
          <div class="mt-8 space-y-5 w-full">
            <div class="rounded-xl border border-green-500/20 bg-green-500/5 p-5">
              <span class="text-xs font-black text-green-400 uppercase block mb-2 tracking-widest" data-i18n="about.freeSectionTitle">Free Beats (Non-Profit)</span>
              <p class="text-[13px] text-gray-300 leading-relaxed italic" data-i18n="about.freeSectionDesc">Evaluate for free. Credit is mandatory (Prod. by Mr. Bonzo). For whitelisting, contact me.</p>
            </div>
            <div class="rounded-xl border border-fuchsia-500/20 bg-fuchsia-500/5 p-5">
              <span class="text-xs font-black text-fuchsia-400 uppercase block mb-2 tracking-widest" data-i18n="about.boughtTitle">Paid Licenses (Claims)</span>
              <p class="text-[13px] text-gray-300 leading-relaxed italic" data-i18n="about.boughtDesc">Purchased? Send YT link + receipt. Claims cleared within 24h.</p>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-12 flex flex-col items-center gap-8 sm:flex-row sm:justify-between border-t border-white/10 pt-8">
        <div class="flex items-center gap-6">
          <button id="prevBtn" class="p-3 border border-fuchsia-500/30 rounded-full hover:bg-fuchsia-500/20 active:scale-95 transition-all" aria-label="Previous about slide" data-i18n-aria-label="ui.aboutPrevSlideAriaLabel">
            <svg class="w-5 h-5 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 19l-7-7 7-7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          
          <div class="flex gap-3">
            <div id="dot-0" class="dot h-1.5 w-8 bg-fuchsia-500 rounded-full transition-all duration-300"></div>
            <div id="dot-1" class="dot h-1.5 w-2 bg-fuchsia-500/20 rounded-full transition-all duration-300"></div>
            <div id="dot-2" class="dot h-1.5 w-2 bg-fuchsia-500/20 rounded-full transition-all duration-300"></div>
          </div>

          <button id="nextBtn" class="p-3 border border-fuchsia-500/30 rounded-full hover:bg-fuchsia-500/20 active:scale-95 transition-all" aria-label="Next about slide" data-i18n-aria-label="ui.aboutNextSlideAriaLabel">
            <svg class="w-5 h-5 text-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>

        <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto text-center rounded-full bg-fuchsia-600 px-10 py-4 text-[12px] font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-fuchsia-600/20 hover:bg-fuchsia-500 transition-all" data-i18n="about.contactBtn">
          Contact for Customs
        </a>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  (function() {
    let current = 0;
    const slides = [document.getElementById('slide-0'), document.getElementById('slide-1'), document.getElementById('slide-2')];
    const dots = [document.getElementById('dot-0'), document.getElementById('dot-1'), document.getElementById('dot-2')];
    
    function showSlide(index) {
      slides.forEach((s, i) => {
        if (!s || !dots[i]) return;
        const isActive = i === index;
        
        s.style.opacity = isActive ? '1' : '0';
        s.style.pointerEvents = isActive ? 'auto' : 'none';
        s.style.position = isActive ? 'relative' : 'absolute';
        s.style.transform = isActive ? 'translateX(0)' : (i > index ? 'translateX(20px)' : 'translateX(-20px)');

        dots[i].className = `dot h-1.5 transition-all duration-300 rounded-full ${isActive ? 'w-8 bg-fuchsia-500' : 'w-2 bg-fuchsia-500/20'}`;
      });
      current = index;
    }

    document.getElementById('nextBtn')?.addEventListener('click', () => showSlide((current + 1) % 3));
    document.getElementById('prevBtn')?.addEventListener('click', () => showSlide((current + 2) % 3));
  })();
</script>