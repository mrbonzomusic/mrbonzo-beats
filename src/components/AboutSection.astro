---
import { aboutContent } from "../config/about";
import { socialLinks } from "../config/links";

const licenses = [
  {
    name: "Basic Lease",
    price: "$29.99",
    features: ["MP3 File", "5,000 Copies", "200k Streams", "50% Writer Share"]
  },
  {
    name: "Premium Lease",
    price: "$49.99",
    features: ["WAV + MP3", "10,000 Copies", "500k Streams", "5 Radio Stations", "50% Writer Share"]
  },
  {
    name: "Exclusive License",
    price: "$150.00",
    features: ["Full Ownership", "Trackouts + WAV", "Unlimited Everything", "50% Writer Share"]
  }
];
---

<section id="about" class="relative mt-16 overflow-hidden rounded-3xl border border-fuchsia-500/30 bg-black">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_20%,rgba(168,85,247,0.18),transparent_40%),radial-gradient(circle_at_80%_70%,rgba(217,70,239,0.14),transparent_45%)]"></div>

  <div class="relative grid items-stretch gap-0 lg:grid-cols-[1fr_1.2fr]">
    
    <div class="relative min-h-[300px] sm:min-h-[400px] lg:min-h-[620px]">
      <img
        src="/images/Mr-Bonzo-half-face.webp"
        alt="Mr. Bonzo portrait"
        class="h-full w-full object-cover object-center"
        loading="lazy"
      />
      <div class="pointer-events-none absolute inset-y-0 right-0 hidden w-28 bg-gradient-to-r from-transparent to-black lg:block"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-b from-transparent to-black lg:hidden"></div>
    </div>

    <div class="relative flex flex-col justify-between px-4 py-10 sm:px-10 lg:px-16 lg:py-16 text-center lg:text-left">
      
      <div class="relative overflow-hidden min-h-[420px] sm:min-h-[400px]">
        
        <div id="slide-0" class="slide transition-all duration-500 transform opacity-100 translate-x-0 relative">
          <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-fuchsia-300/85">The Artist</p>
          <h2 class="mt-3 text-2xl font-black uppercase tracking-tight text-white sm:text-4xl lg:text-5xl">
            The Architect of Energy
          </h2>
          <p class="mt-5 text-sm leading-relaxed text-purple-100/85 sm:text-base">
            {aboutContent.en.bio}
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
            <span class="rounded-full border border-fuchsia-500/40 px-3 py-1 text-[9px] font-bold uppercase text-fuchsia-200">Beatmaker</span>
            <span class="rounded-full border border-fuchsia-500/40 px-3 py-1 text-[9px] font-bold uppercase text-fuchsia-200">Engineer</span>
            <span class="rounded-full border border-fuchsia-500/40 px-3 py-1 text-[9px] font-bold uppercase text-fuchsia-200">Producer</span>
          </div>
        </div>

        <div id="slide-1" class="slide absolute top-0 left-0 w-full transition-all duration-500 transform opacity-0 translate-x-full pointer-events-none">
          <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-fuchsia-300/85">Terms & Usage</p>
          <h2 class="mt-3 text-2xl font-black uppercase tracking-tight text-white sm:text-4xl">Licensing Guide</h2>
          <div class="mt-6 space-y-3">
            {licenses.map((license) => (
              <div class="rounded-xl border border-white/5 bg-white/5 p-3 sm:p-4 text-left transition hover:border-fuchsia-500/40 group">
                <div class="flex justify-between items-center mb-1">
                  <h3 class="font-black uppercase text-fuchsia-300 text-[10px] sm:text-xs tracking-wide">{license.name}</h3>
                  <span class="text-[9px] font-black text-white bg-fuchsia-500/20 px-2 py-0.5 rounded border border-fuchsia-500/30">{license.price}</span>
                </div>
                <p class="text-[9px] sm:text-[10px] text-purple-100/70 leading-relaxed italic">
                  {license.features.join(" • ")}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div id="slide-2" class="slide absolute top-0 left-0 w-full transition-all duration-500 transform opacity-0 translate-x-full pointer-events-none">
          <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-green-400">Claims & Whitelisting</p>
          <h2 class="mt-3 text-2xl font-black uppercase text-white sm:text-4xl">Usage Policy</h2>
          <div class="mt-6 space-y-3 text-left">
            <div class="rounded-xl border border-green-500/20 bg-green-500/5 p-4">
              <h3 class="text-[10px] font-bold uppercase text-green-400 mb-1 tracking-widest">100% Free Beats</h3>
              <p class="text-[10px] sm:text-xs text-gray-300 leading-relaxed italic">
                Beats in the "Free Section" are free for profit. Copyright claim? Contact me with your video link to whitelist you.
              </p>
            </div>
            <div class="rounded-xl border border-fuchsia-500/20 bg-fuchsia-500/10 p-4">
              <h3 class="text-[10px] font-bold uppercase text-fuchsia-400 mb-1 tracking-widest">Bought a License?</h3>
              <p class="text-[10px] sm:text-xs text-gray-300 leading-relaxed italic">
                Send your **YouTube link** and **receipt screenshot**. I will clear the claim within 24 hours.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-col items-center justify-between gap-6 sm:flex-row">
        <div class="flex items-center gap-4 order-2 sm:order-1">
          <button id="prevBtn" class="group rounded-full border border-fuchsia-500/30 p-2.5 transition hover:bg-fuchsia-500/20 active:scale-90">
            <svg class="h-4 w-4 stroke-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          
          <div class="flex gap-2">
            <div id="dot-0" class="dot h-1.5 w-6 rounded-full bg-fuchsia-500 transition-all duration-300"></div>
            <div id="dot-1" class="dot h-1.5 w-2 rounded-full bg-fuchsia-500/20 transition-all duration-300"></div>
            <div id="dot-2" class="dot h-1.5 w-2 rounded-full bg-fuchsia-500/20 transition-all duration-300"></div>
          </div>

          <button id="nextBtn" class="group rounded-full border border-fuchsia-500/30 p-2.5 transition hover:bg-fuchsia-500/20 active:scale-90">
            <svg class="h-4 w-4 stroke-fuchsia-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>

        <a
          href={socialLinks.instagram}
          target="_blank"
          class="order-1 sm:order-2 w-full sm:w-auto inline-flex items-center justify-center rounded-full bg-fuchsia-600 px-8 py-3 text-[10px] font-black uppercase tracking-[0.2em] text-white transition hover:bg-fuchsia-500 active:scale-95"
        >
          Contact for Customs
        </a>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  let current = 0;
  const slides = [document.getElementById('slide-0'), document.getElementById('slide-1'), document.getElementById('slide-2')];
  const dots = [document.getElementById('dot-0'), document.getElementById('dot-1'), document.getElementById('dot-2')];

  function showSlide(index) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.remove('opacity-0', 'translate-x-full', '-translate-x-full', 'pointer-events-none', 'absolute');
        slide.classList.add('opacity-100', 'translate-x-0', 'relative');
        dots[i].classList.remove('w-2', 'bg-fuchsia-500/20');
        dots[i].classList.add('w-6', 'bg-fuchsia-500');
      } else {
        slide.classList.add('opacity-0', 'pointer-events-none', 'absolute');
        slide.classList.remove('opacity-100', 'translate-x-0', 'relative');
        dots[i].classList.add('w-2', 'bg-fuchsia-500/20');
        dots[i].classList.remove('w-6', 'bg-fuchsia-500');
        if (i < index) slide.classList.add('-translate-x-full');
        else slide.classList.add('translate-x-full');
      }
    });
    current = index;
  }

  document.getElementById('nextBtn').addEventListener('click', () => showSlide((current + 1) % slides.length));
  document.getElementById('prevBtn').addEventListener('click', () => showSlide((current - 1 + slides.length) % slides.length));
</script>