---
import { socialLinks } from "../config/links";
---

<section id="contact" class="relative mt-16 py-16 px-6 overflow-hidden rounded-3xl border border-fuchsia-500/20 bg-black/50 backdrop-blur-sm">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(168,85,247,0.1),transparent_70%)] pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-fuchsia-400 mb-4" data-i18n="contact.label">Contact</p>
    <h2 class="text-4xl md:text-5xl font-black uppercase text-white mb-8" data-i18n="contact.title">Let's Create <span class="text-fuchsia-500">History</span></h2>
    
    <p class="text-gray-400 mb-12 max-w-xl mx-auto" data-i18n="contact.subtitle">
      Whether it's a custom beat, mixing & mastering, or a collaboration, my door is always open.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <a 
        href={socialLinks.email} 
        class="group relative z-20 flex flex-col items-center p-8 rounded-2xl border border-white/5 bg-white/5 hover:border-fuchsia-500/40 transition-all duration-300 cursor-pointer"
      >
        <div class="mb-4 p-3 rounded-full bg-fuchsia-500/10 group-hover:bg-fuchsia-500/20 transition-colors">
          <svg class="w-6 h-6 text-fuchsia-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <span class="text-xs font-bold uppercase tracking-widest text-white mb-1">Email</span>
        <span class="text-sm text-gray-500 group-hover:text-fuchsia-300 transition-colors lowercase">
          {socialLinks.email.replace('mailto:', '')}
        </span>
      </a>

      <a 
        href={socialLinks.instagram} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="group relative z-20 flex flex-col items-center p-8 rounded-2xl border border-white/5 bg-white/5 hover:border-fuchsia-500/40 transition-all duration-300 cursor-pointer"
      >
        <div class="mb-4 p-3 rounded-full bg-fuchsia-500/10 group-hover:bg-fuchsia-500/20 transition-colors">
          <svg class="w-6 h-6 text-fuchsia-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </div>
        <span class="text-xs font-bold uppercase tracking-widest text-white mb-1">Instagram</span>
        <span class="text-sm text-gray-500 group-hover:text-fuchsia-300 transition-colors">@mrbonzobeats</span>
      </a>

      <a 
        href={socialLinks.discord} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="group relative z-20 flex flex-col items-center p-8 rounded-2xl border border-white/5 bg-white/5 hover:border-fuchsia-500/40 transition-all duration-300 cursor-pointer"
      >
        <div class="mb-4 p-3 rounded-full bg-fuchsia-500/10 group-hover:bg-fuchsia-500/20 transition-colors">
          <svg class="w-6 h-6 text-fuchsia-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037 19.736 19.736 0 0 0-4.885 1.515.069.069 0 0 0-.032.027C.533 9.048-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.23 10.23 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 1-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
          </svg>
        </div>
        <span class="text-xs font-bold uppercase tracking-widest text-white mb-1">Discord</span>
        <span class="text-sm text-gray-500 group-hover:text-fuchsia-300 transition-colors">Join the Studio</span>
      </a>
    </div>
  </div>
</section>