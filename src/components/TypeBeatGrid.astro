---
const channelPlaylistsUrl = "https://www.youtube.com/@mrbonzobeatz/playlists";

const playlists = [
  {
    title: "Boom Bap Beats",
    href: "https://www.youtube.com/playlist?list=PLMdNnt6p6RrEdkjzDdS12hUJNx8ENBul6",
    image: "/images/Boom-Bap-Beats.webp",
    beatstarsHref: "https://www.beatstars.com/playlists/5350129"
  },
  {
    title: "Trap Beats",
    href: "https://www.youtube.com/playlist?list=PLMdNnt6p6RrEotLVDWzYhCLVH_fG3kn93",
    image: "/images/Trap-Beats.webp",
    beatstarsHref: "https://www.beatstars.com/playlists/5319147"
  },
  {
    title: "Free Beats",
    href: "https://www.youtube.com/playlist?list=PLMdNnt6p6RrEt5bZVQd1bZZ21DUj7LvyW",
    image: "/images/Free-Beats.webp",
    beatstarsHref: "https://www.beatstars.com/playlists/6148560"
  }
];
---

<section id="beats" class="mt-20 scroll-mt-32">
  <div class="mb-8 flex items-end justify-between gap-4 border-b border-fuchsia-500/10 pb-4">
    <h2 class="text-3xl font-extrabold uppercase tracking-tight text-white sm:text-4xl lg:text-5xl" data-i18n="playlists.title">
      YouTube Playlists
    </h2>
    <a
      href={channelPlaylistsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-base font-bold uppercase tracking-wide text-fuchsia-400 hover:text-fuchsia-300 transition-colors"
      data-i18n="playlists.viewAll"
    >
      View All
    </a>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      playlists.map((playlist) => (
        <article class="group rounded-2xl border border-fuchsia-500/20 bg-black/40 p-5 shadow-[0_0_24px_rgba(192,38,211,0.1)] transition-all duration-300 hover:-translate-y-2 hover:border-fuchsia-500/60 hover:shadow-fuchsia-500/20">
          <div class="relative aspect-video overflow-hidden rounded-xl border border-fuchsia-500/30 bg-black">
            <img
              src={playlist.image}
              alt={playlist.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            
            <h3 class="absolute bottom-4 left-4 right-4 text-lg font-black uppercase tracking-[0.15em] text-white sm:text-xl">
              {playlist.title}
            </h3>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <a
              href={playlist.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex rounded-full border border-fuchsia-500/40 px-5 py-2.5 text-[13px] font-black uppercase tracking-widest text-fuchsia-200 transition hover:border-fuchsia-300 hover:text-fuchsia-100 hover:bg-fuchsia-500/5"
              data-i18n="playlists.open"
            >
              Open
            </a>
            <a
              href={playlist.beatstarsHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex rounded-full border border-fuchsia-400/50 bg-fuchsia-600 px-5 py-2.5 text-[13px] font-black uppercase tracking-widest text-white shadow-lg shadow-fuchsia-600/20 transition hover:bg-fuchsia-500 hover:scale-105 active:scale-95"
              data-i18n={playlist.title === "Free Beats" ? "playlists.free" : "playlists.shop"}
            >
              {playlist.title === "Free Beats" ? "Free Download" : "Shop on Beatstars"}
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>