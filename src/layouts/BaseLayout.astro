---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <main class="mx-auto max-w-7xl px-4 pb-6 pt-0 sm:px-6 lg:px-8">
      
      <header class="sticky top-2 z-50 mb-4 px-2">
        <div class="rounded-[1.5rem] md:rounded-full border border-fuchsia-500/20 bg-black/90 backdrop-blur-md p-2 sm:px-6">
          
          <div class="flex items-center justify-between gap-4 mb-2 md:mb-0">
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[20px] sm:h-[30px] md:h-[35px] w-auto" />
            </a>

            <div class="flex items-center gap-2">
              <div class="flex items-center gap-1 font-bold text-[10px] border-r border-fuchsia-500/20 pr-2">
                <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 transition data-[active=true]:text-fuchsia-400 px-1">EN</button>
                <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 transition data-[active=true]:text-fuchsia-400 px-1">EL</button>
              </div>
              <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600/20 border border-fuchsia-500/30 px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-fuchsia-300 hover:bg-fuchsia-500 hover:text-white transition" data-i18n="nav.store">Store</a>
            </div>
          </div>

          <nav class="flex flex-wrap items-center justify-center md:justify-start gap-x-4 gap-y-2 border-t border-white/5 pt-2 md:border-none md:pt-0 md:inline-flex md:ml-8">
            <a href="#beats" class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="nav.beats">Beats</a>
            <a href="#drumkits" class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="nav.kits">Kits</a>
            
            <div class="relative group cursor-pointer">
              <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-red-500/80 flex items-center gap-0.5">
                YouTube <svg class="h-2 w-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
              </span>
              <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute top-full left-0 mt-2 w-32 rounded-xl border border-white/10 bg-black/95 p-1 z-50 transition-all shadow-2xl">
                <a href={ytArtist} target="_blank" class="block rounded-lg px-2 py-2 text-[8px] font-bold uppercase text-white hover:bg-red-600/20">Artist Channel</a>
                <a href={ytBeats} target="_blank" class="block rounded-lg px-2 py-2 text-[8px] font-bold uppercase text-white hover:bg-red-600/20 border-t border-white/5">Beats Channel</a>
              </div>
            </div>

            <a href={discordInvite} target="_blank" class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-[#5865F2] transition hover:text-[#7289da]" data-i18n="nav.discord">Discord</a>
            <a href={socialLinks.spotify} target="_blank" class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-green-500/80 transition hover:text-green-500" data-i18n="nav.spotify">Spotify</a>
            <a href="#contact" class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="contact.label">Contact</a>
          </nav>

        </div>
      </header>

      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      const dictionaries = i18nPayload;
      const getByPath = (obj, path) => path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj);
      
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        document.documentElement.lang = lang;
        localStorage.setItem("site-lang", lang);
        
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const value = key ? getByPath(dict, key) : null;
          if (typeof value === "string") {
            node.innerHTML = value;
          }
        });
        
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          btn.setAttribute("data-active", btn.getAttribute("data-lang-switch") === lang ? "true" : "false");
        });
      };

      const initial = localStorage.getItem("site-lang") || "en";
      applyLanguage(initial);
      
      document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
        btn.addEventListener("click", () => applyLanguage(btn.getAttribute("data-lang-switch")));
      });
    </script>
  </body>
</html>