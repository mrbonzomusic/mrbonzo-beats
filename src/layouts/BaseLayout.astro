---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Official" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

// --- SEO & CONFIG ---
const siteDescription = "Official website of Mr. Bonzo. High-quality trap beats and exclusive drum kits.";
const ogImageURL = "https://mrbonzo-beats.pages.dev/images/og-image.jpg";
const siteURL = "https://mrbonzo-beats.pages.dev/";

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const tikTokLink = "https://www.tiktok.com/@mrbonzomusic"; 
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={siteDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#000000" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={`${ogImageURL}?v=2`} />

    <style is:global>
      header#main-header {
        position: fixed !important;
        top: 0 !important; left: 0 !important; right: 0 !important;
        z-index: 9999999 !important;
        padding-top: 0.75rem;
      }
      body { padding-top: 90px !important; background-color: black; }
      #mobile-menu { max-height: calc(100vh - 120px); overflow-y: auto; }

      .nav-dropdown { position: relative; display: inline-block; padding-bottom: 20px; margin-bottom: -20px; }
      .nav-dropdown-content {
        display: none;
        position: absolute;
        background-color: rgba(0, 0, 0, 0.95);
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
        z-index: 1000;
        border: 1px solid rgba(217, 70, 239, 0.2);
        border-radius: 14px;
        margin-top: 5px;
        backdrop-filter: blur(12px);
      }
      .nav-dropdown:hover .nav-dropdown-content { display: block; animation: dropdownFade 0.2s ease-out; }
      @keyframes dropdownFade { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
      .nav-dropdown-content a { color: rgba(250, 232, 255, 0.75); padding: 12px 16px; display: block; font-size: 11px; font-weight: bold; text-transform: uppercase; transition: all 0.2s ease; }
      .nav-dropdown-content a:hover { color: #e879f9; background-color: rgba(255, 255, 255, 0.08); }
    </style>
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <header id="main-header">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/90 backdrop-blur-md px-5 py-2.5 shadow-2xl">
          <div class="flex items-center justify-between">
            
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[22px] w-auto sm:h-[30px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-4 xl:gap-x-6">
              <a href="#player" class="text-xs font-bold uppercase tracking-wider text-fuchsia-400 hover:text-fuchsia-300 transition">Player</a>
              <a href="#beats" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Beats</a>
              <a href="#drumkits" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Kits</a>
              <div class="nav-dropdown" tabindex="0">
                <button class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition flex items-center gap-1.5 outline-none">
                  YouTube <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <div class="nav-dropdown-content">
                  <a href={ytBeats} target="_blank">Beats Channel</a>
                  <a href={ytArtist} target="_blank">Artist Channel</a>
                </div>
              </div>
              <a href={socialLinks.spotify} target="_blank" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Spotify</a>
              <a href={tikTokLink} target="_blank" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">TikTok</a>
              <a href={discordInvite} target="_blank" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Discord</a>
              <a href={pond5Link} target="_blank" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Pond5</a>
              <a href="#about" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">About</a>
              <a href="#contact" class="text-xs font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Contact</a>
            </nav>

            <div class="flex items-center gap-2">
               <div class="flex items-center gap-1 font-bold text-[9px] sm:text-[10px] border-r border-fuchsia-500/20 pr-2">
                  <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-400 px-1 hover:text-fuchsia-100 transition">EN</button>
                  <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-400 px-1 hover:text-fuchsia-100 transition">EL</button>
               </div>
               
               <button id="share-btn" class="p-1.5 text-fuchsia-400 hover:text-white transition-all active:scale-90 relative">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                  </svg>
                  <span id="share-tooltip" class="absolute -bottom-10 left-1/2 -translate-x-1/2 bg-fuchsia-600 text-[9px] font-black uppercase px-2 py-1 rounded shadow-xl pointer-events-none opacity-0 transition-opacity">Copied!</span>
               </button>

               <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600 px-4 py-1.5 text-[9px] font-black uppercase text-white hover:bg-fuchsia-500 transition">Store</a>

               <button id="burger-btn" class="lg:hidden p-1 text-fuchsia-100/70 hover:text-fuchsia-400 transition outline-none">
                <svg id="b-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M4 6h16M4 12h16m-7 6h7"/></svg>
                <svg id="b-close" class="hidden w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
               </button>
            </div>
          </div>
        </div>

        <div id="mobile-menu" class="hidden lg:hidden mt-3 mx-1 rounded-[2rem] border border-fuchsia-500/20 bg-black/95 backdrop-blur-2xl p-6 shadow-2xl">
          <nav class="flex flex-col gap-4 text-center">
            <a href="#player" class="m-link text-base font-black uppercase text-fuchsia-400">Player</a>
            <a href="#beats" class="m-link text-base font-black uppercase text-fuchsia-100/80">Beats</a>
            <a href="#drumkits" class="m-link text-base font-black uppercase text-fuchsia-100/80">Drum Kits</a>
            
            <div class="flex flex-col items-center">
              <button id="m-yt-trigger" class="flex items-center gap-2 text-base font-black uppercase text-fuchsia-100/80 outline-none py-2">
                YouTube <svg id="m-yt-icon" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div id="m-yt-content" class="hidden flex-col w-full bg-white/5 rounded-2xl overflow-hidden mt-2 border border-white/5">
                <a href={ytBeats} target="_blank" class="py-4 border-b border-white/5 text-sm font-bold text-fuchsia-200/70 active:bg-white/10">Beats Channel</a>
                <a href={ytArtist} target="_blank" class="py-4 text-sm font-bold text-fuchsia-200/70 active:bg-white/10">Artist Channel</a>
              </div>
            </div>

            <a href={socialLinks.spotify} target="_blank" class="m-link text-base font-black uppercase text-fuchsia-100/80">Spotify</a>
            <a href={tikTokLink} target="_blank" class="m-link text-base font-black uppercase text-fuchsia-100/80">TikTok</a>
            <a href={discordInvite} target="_blank" class="m-link text-base font-black uppercase text-fuchsia-100/80">Discord</a>
            <a href={pond5Link} target="_blank" class="m-link text-base font-black uppercase text-fuchsia-100/80">Pond5</a>
            <a href="#about" class="m-link text-base font-black uppercase text-fuchsia-100/80">About</a>
            <a href="#contact" class="m-link text-base font-black uppercase text-fuchsia-400">Contact</a>
            
            <div class="flex justify-center gap-4 pt-6 border-t border-white/5">
              <button type="button" data-lang-switch="en" class="text-xs font-bold text-fuchsia-200/40 data-[active=true]:text-fuchsia-400 px-3 py-1">ENGLISH</button>
              <button type="button" data-lang-switch="el" class="text-xs font-bold text-fuchsia-200/40 data-[active=true]:text-fuchsia-400 px-3 py-1">ΕΛΛΗΝΙΚΑ</button>
            </div>
          </nav>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload, title, siteURL }}>
      // I18N
      const dictionaries = i18nPayload;
      const getByPath = (obj, path) => path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj);
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        document.documentElement.lang = lang;
        localStorage.setItem("site-lang", lang);
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const value = key ? getByPath(dict, key) : null;
          if (typeof value === "string") node.innerHTML = value;
        });
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          btn.setAttribute("data-active", btn.getAttribute("data-lang-switch") === lang ? "true" : "false");
        });
      };
      applyLanguage(localStorage.getItem("site-lang") || "en");
      document.querySelectorAll("[data-lang-switch]").forEach(btn => {
        btn.addEventListener("click", () => applyLanguage(btn.getAttribute("data-lang-switch")));
      });

      // Mobile Youtube Dropdown
      const ytTrigger = document.getElementById('m-yt-trigger');
      const ytContent = document.getElementById('m-yt-content');
      const ytIcon = document.getElementById('m-yt-icon');
      ytTrigger?.addEventListener('click', () => {
        const isHidden = ytContent.classList.toggle('hidden');
        ytIcon.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
      });

      // Mobile Menu logic
      const bBtn = document.getElementById('burger-btn');
      const mMenu = document.getElementById('mobile-menu');
      const bOpen = document.getElementById('b-open');
      const bClose = document.getElementById('b-close');

      bBtn?.addEventListener('click', () => {
        const isHidden = mMenu.classList.toggle('hidden');
        bOpen.classList.toggle('hidden', !isHidden);
        bClose.classList.toggle('hidden', isHidden);
        document.body.style.overflow = isHidden ? 'auto' : 'hidden';
      });

      document.querySelectorAll('.m-link').forEach(l => l.addEventListener('click', () => {
        mMenu.classList.add('hidden');
        bOpen.classList.remove('hidden');
        bClose.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }));

      // Share logic
      const shareBtn = document.getElementById('share-btn');
      const tooltip = document.getElementById('share-tooltip');
      shareBtn?.addEventListener('click', async () => {
        if (navigator.share) {
          try {
            await navigator.share({ title, text: 'Check out Mr. Bonzo Beats', url: siteURL });
          } catch (err) {}
        } else {
          await navigator.clipboard.writeText(siteURL);
          tooltip.classList.add('opacity-100');
          setTimeout(() => tooltip.classList.remove('opacity-100'), 2000);
        }
      });
    </script>
  </body>
</html>