---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <style is:global>
      /* ΒΙΑΙΗ ΕΠΙΒΟΛΗ ΧΡΩΜΑΤΩΝ ΚΑΙ POSITION */
      header#super-header {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        z-index: 2147483647 !important;
        background-color: rgba(0, 0, 0, 0.9) !important;
        backdrop-filter: blur(15px) !important;
        -webkit-backdrop-filter: blur(15px) !important;
        border-bottom: 1px solid rgba(217, 70, 239, 0.3) !important;
      }

      /* Χρώμα συνδέσμων - FORCE FUCHSIA */
      .nav-link-fuchsia {
        color: #d946ef !important; /* Fuchsia-400 */
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.15em !important;
        transition: color 0.3s ease !important;
      }

      .nav-link-fuchsia:hover {
        color: #ffffff !important;
        text-shadow: 0 0 10px rgba(217, 70, 239, 0.8) !important;
      }

      body {
        padding-top: 85px !important;
        margin: 0 !important;
        background-color: black !important;
      }

      /* Διόρθωση για να μην μπαίνουν τα IFRAME μπροστά */
      iframe {
        position: relative !important;
        z-index: 1 !important;
      }
    </style>
  </head>

  <body class="bg-black text-white antialiased">
    
    <header id="super-header" class="py-3">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-full border border-fuchsia-500/30 bg-black/40 px-6 py-2 shadow-[0_0_20px_rgba(192,38,211,0.25)]">
          <div class="flex items-center justify-between">
            
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[22px] w-auto sm:h-[28px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-6">
              <a href="#beats" class="nav-link-fuchsia text-[10px]" data-i18n="nav.beats">Beats</a>
              <a href="#drumkits" class="nav-link-fuchsia text-[10px]" data-i18n="nav.kits">Kits</a>
              <a href="#player" class="nav-link-fuchsia text-[10px]" data-i18n="nav.player">Player</a>
              
              <div class="relative group cursor-pointer">
                <button type="button" class="nav-link-fuchsia text-[10px] flex items-center gap-1 outline-none">
                  YouTube <svg class="h-2 w-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute top-full left-0 mt-3 w-44 rounded-xl border border-fuchsia-500/20 bg-black/95 p-1 shadow-2xl transition-all">
                  <a href={ytArtist} target="_blank" class="block rounded-lg px-4 py-2 text-[10px] font-bold uppercase text-fuchsia-400 hover:text-white hover:bg-fuchsia-600/20 transition">Artist Channel</a>
                  <a href={ytBeats} target="_blank" class="block rounded-lg px-4 py-2 text-[10px] font-bold uppercase text-fuchsia-400 hover:text-white hover:bg-fuchsia-600/20 border-t border-white/5 transition">Beats Channel</a>
                </div>
              </div>

              <a href={socialLinks.spotify} target="_blank" class="nav-link-fuchsia text-[10px]">Spotify</a>
              <a href="#about" class="nav-link-fuchsia text-[10px]" data-i18n="about.label">About</a>
              <a href="#contact" class="nav-link-fuchsia text-[10px]" data-i18n="contact.label">Contact</a>
            </nav>

            <div class="flex items-center gap-4">
               <div class="flex items-center font-bold text-[9px] border-r border-fuchsia-500/20 pr-3 mr-1">
                  <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-500 px-1 hover:text-white transition">EN</button>
                  <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-500 px-1 hover:text-white transition">EL</button>
               </div>
               
               <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600 px-5 py-1.5 text-[9px] font-black uppercase text-white shadow-[0_0_15px_rgba(192,38,211,0.5)] hover:bg-fuchsia-500 transition">Store</a>

               <button id="burger-btn" class="lg:hidden text-fuchsia-500 p-1">
                 <svg id="burger-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
                 <svg id="burger-close" class="hidden w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
               </button>
            </div>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="hidden fixed inset-0 top-[85px] bg-black/95 backdrop-blur-3xl z-">
        <div class="flex flex-col gap-6 p-10">
          <a href="#beats" class="mobile-link text-2xl font-black uppercase text-fuchsia-500 border-b border-fuchsia-500/10 pb-4">Beats</a>
          <a href="#drumkits" class="mobile-link text-2xl font-black uppercase text-fuchsia-500 border-b border-fuchsia-500/10 pb-4">Drum Kits</a>
          <a href="#player" class="mobile-link text-2xl font-black uppercase text-fuchsia-500 border-b border-fuchsia-500/10 pb-4">Player</a>
          <a href="#about" class="mobile-link text-2xl font-black uppercase text-fuchsia-500 border-b border-fuchsia-500/10 pb-4">About</a>
          <a href="#contact" class="mobile-link text-2xl font-black uppercase text-white bg-fuchsia-600 px-6 py-3 rounded-xl text-center shadow-lg">Contact</a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      const dictionaries = i18nPayload;
      const getByPath = (obj, path) => path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj);
      
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        document.documentElement.lang = lang;
        localStorage.setItem("site-lang", lang);
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const value = key ? getByPath(dict, key) : null;
          if (typeof value === "string") node.innerHTML = value;
        });
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          btn.setAttribute("data-active", btn.getAttribute("data-lang-switch") === lang ? "true" : "false");
        });
      };

      applyLanguage(localStorage.getItem("site-lang") || "en");

      document.querySelectorAll("[data-lang-switch]").forEach(btn => {
        btn.addEventListener("click", () => applyLanguage(btn.getAttribute("data-lang-switch")));
      });

      const burgerBtn = document.getElementById('burger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const burgerOpen = document.getElementById('burger-open');
      const burgerClose = document.getElementById('burger-close');

      burgerBtn.addEventListener('click', () => {
        const isOpen = mobileMenu.classList.toggle('hidden');
        burgerOpen.classList.toggle('hidden');
        burgerClose.classList.toggle('hidden');
        document.body.style.overflow = isOpen ? 'auto' : 'hidden';
      });

      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          burgerOpen.classList.remove('hidden');
          burgerClose.classList.add('hidden');
          document.body.style.overflow = 'auto';
        });
      });
    </script>
  </body>
</html>