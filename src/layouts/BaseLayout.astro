---
import "../styles/global.css";
import { beatstarsLinks, socialLinks } from "../config/links";
import en from "../i18n/en";
import el from "../i18n/el";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Official Website" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const socialPreviewImage = "https://mrbonzo-beats.pages.dev/og-image-v2.jpg";
const siteDescription = "The official website of Mr. Bonzo. Music production, high-quality trap beats, and exclusive drum kits.";
const siteURL = "https://mrbonzo-beats.pages.dev/";

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J";
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const tikTokLink = "https://www.tiktok.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const spotifyLink = socialLinks.spotify;
const translations = { en, el };
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <meta name="description" content={siteDescription} />
    <meta property="og:url" content={siteURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={socialPreviewImage} />
    
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFJSZGBGZE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QFJSZGBGZE');
    </script>

    <style is:global>
      /* --- BaseBox Banner --- */
      .basebox-banner {
        background: linear-gradient(90deg, #000, #1a001a, #000);
        color: #fff;
        text-align: center;
        padding: 8px 16px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(217, 70, 239, 0.2);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10000001;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 40px;
      }
      
      .basebox-banner a { 
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: inherit; 
        text-decoration: none; 
      }
      .basebox-banner strong { color: #d946ef; font-weight: 900; }
      
      .basebox-badge {
        background: rgba(217, 70, 239, 0.15);
        color: #d946ef;
        padding: 2px 10px;
        border-radius: 99px;
        font-size: 9px;
        border: 1px solid rgba(217, 70, 239, 0.4);
        white-space: nowrap;
      }

      /* Desktop vs Mobile Text */
      .banner-desktop-text { display: inline; }
      .banner-mobile-text { display: none; }

      @media (max-width: 640px) {
        .basebox-banner { 
          font-size: 9px; 
          padding: 6px 10px;
          min-height: 36px; 
        }
        .banner-desktop-text { display: none; }
        .banner-mobile-text { display: inline; }
        .basebox-banner a { gap: 5px; }
        .basebox-badge { font-size: 8px; padding: 1px 6px; }
      }

      /* --- Header & Layout --- */
      header#main-header {
        position: fixed !important;
        left: 0 !important;
        right: 0 !important;
        z-index: 9999999 !important;
        padding-top: 0.75rem;
        transition: top 0.2s ease;
      }

      body { background-color: black; }

      .nav-divider { width: 1px; height: 14px; background-color: rgba(217, 70, 239, 0.3); margin: 0 6px; flex-shrink: 0; }
      .nav-dropdown { position: relative; display: inline-block; padding-bottom: 20px; margin-bottom: -20px; }
      .nav-dropdown-content {
        display: none; position: absolute; background-color: rgba(0, 0, 0, 0.95);
        min-width: 160px; box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
        z-index: 1000; border: 1px solid rgba(217, 70, 239, 0.2);
        border-radius: 14px; margin-top: 5px; backdrop-filter: blur(12px);
      }
      .nav-dropdown:hover .nav-dropdown-content { display: block; }
      
      #mobile-menu.hidden { display: none; }
      .mobile-link { display: block; padding: 0.85rem 1rem; color: #e5e7eb; font-weight: 800; text-transform: uppercase; font-size: 11px; }
    </style>
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    
    <!-- ΔΙΑΚΡΙΤΙΚΟ BANNER -->
    <div class="basebox-banner">
      <a href="https://forms.gle/AC86bRqwhfNmbCUh9" target="_blank" rel="noopener noreferrer">
        <span>🚀 <strong>BASEBOX</strong>:</span>
        <span class="banner-desktop-text">The Automated Artist & Catalog Manager. Send to PROs in seconds.</span> 
        <span class="banner-mobile-text">The AI Artist Manager.</span>
        <span class="basebox-badge">GET ACCESS</span>
      </a>
    </div>

    <header id="main-header">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/90 backdrop-blur-md px-5 py-2.5 shadow-2xl">
          <div class="flex items-center justify-between">
            <a href="/" class="flex-shrink-0">
              <img src={logoPath} alt="Logo" class="h-[22px] w-auto sm:h-[30px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-3">
              <a href="#player" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-400" data-i18n="nav.player">Player</a>
              <a href="#beats" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70" data-i18n="nav.beats">Beats</a>
              <a href="#drumkits" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70" data-i18n="nav.kits">Kits</a>
              
              <div class="nav-divider"></div>

              <div class="nav-dropdown">
                <button class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 flex items-center gap-1">
                  <span data-i18n="nav.youtube">YouTube</span>
                </button>
                <div class="nav-dropdown-content">
                  <a href={ytBeats} target="_blank" class="mobile-link">Beats</a>
                  <a href={ytArtist} target="_blank" class="mobile-link">Artist</a>
                </div>
              </div>

              <a href={spotifyLink} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70">Spotify</a>
              <a href={discordInvite} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70">Discord</a>
            </nav>

            <div class="flex items-center gap-2">
                <div id="language-switcher" class="flex items-center gap-1 font-bold text-[10px] border-r border-fuchsia-500/20 pr-3">
                  <button type="button" data-lang-switch="en" class="lang-switch-btn text-fuchsia-200/40 data-[active=true]:text-fuchsia-400">EN</button>
                  <button type="button" data-lang-switch="el" class="lang-switch-btn text-fuchsia-200/40 data-[active=true]:text-fuchsia-400">EL</button>
                </div>
                <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600 px-4 py-1.5 text-[10px] font-black text-white" data-i18n="nav.store">Store</a>
                <button id="burger-btn" class="lg:hidden p-1 text-fuchsia-400">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 6h16M4 12h16m-7 6h7"/></svg>
                </button>
            </div>
          </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden lg:hidden mt-2">
          <div class="rounded-3xl border border-fuchsia-500/20 bg-black/95 p-4 shadow-2xl">
            <a href="#player" class="mobile-link text-fuchsia-400" data-i18n="nav.player">Player</a>
            <a href="#beats" class="mobile-link" data-i18n="nav.beats">Beats</a>
            <a href={ytBeats} target="_blank" class="mobile-link">YouTube</a>
            <a href={discordInvite} target="_blank" class="mobile-link">Discord</a>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <script is:inline define:vars={{ translations }}>
      const storageKey = 'selected-lang';
      
      function applyTranslations() {
        const lang = localStorage.getItem(storageKey) || 'en';
        const dict = translations[lang];
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          const val = key.split('.').reduce((o, i) => o[i], dict);
          if (val) el.innerText = val;
        });
        document.querySelectorAll('.lang-switch-btn').forEach(btn => {
          btn.setAttribute('data-active', btn.getAttribute('data-lang-switch') === lang);
        });
      }

      function adjustLayout() {
        const banner = document.querySelector('.basebox-banner');
        const header = document.getElementById('main-header');
        if (banner && header) {
          const bH = banner.offsetHeight;
          header.style.top = bH + 'px';
          // Προσθέτουμε το συνολικό ύψος στο body για να μη κρύβεται το Hero
          document.body.style.paddingTop = (bH + header.offsetHeight + 20) + 'px';
        }
      }

      window.addEventListener('resize', adjustLayout);
      window.addEventListener('load', adjustLayout);

      document.querySelectorAll('.lang-switch-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          localStorage.setItem(storageKey, btn.getAttribute('data-lang-switch'));
          applyTranslations();
          setTimeout(adjustLayout, 50);
        });
      });

      const bBtn = document.getElementById('burger-btn');
      const mMenu = document.getElementById('mobile-menu');
      if (bBtn) bBtn.onclick = () => mMenu.classList.toggle('hidden');

      applyTranslations();
      adjustLayout();
    </script>
  </body>
</html>