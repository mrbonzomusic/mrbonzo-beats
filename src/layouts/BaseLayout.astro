---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const pond5Link = "https://www.pond5.com/artist/mrbonzomusic";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <main class="mx-auto max-w-7xl px-4 pb-6 pt-0 sm:px-6 lg:px-8">
      
      <header class="sticky top-4 z- mb-8">
        <div class="rounded-[2rem] border border-fuchsia-500/30 bg-black/90 backdrop-blur-xl px-4 py-2 shadow-[0_0_20px_rgba(168,85,247,0.15)] transition-all duration-300">
          <div class="flex items-center justify-between">
            
            <a href="/" class="z-50 flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[28px] md:h-[35px] w-auto" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-6">
              <a href="#beats" class="text-[10px] font-bold uppercase tracking-widest text-fuchsia-100/70 hover:text-fuchsia-400 transition" data-i18n="nav.beats">Beats</a>
              <a href="#drumkits" class="text-[10px] font-bold uppercase tracking-widest text-fuchsia-100/70 hover:text-fuchsia-400 transition" data-i18n="nav.kits">Kits</a>
              
              <div class="relative group">
                <button type="button" class="text-[10px] font-bold uppercase tracking-widest text-red-500/80 flex items-center gap-0.5 outline-none">
                  YouTube <svg class="h-2 w-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 9l-7 7-7-7" stroke-width="3"/></svg>
                </button>
                <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute top-full left-0 mt-2 w-36 rounded-xl border border-white/10 bg-black p-1 shadow-2xl transition-all">
                  <a href={ytArtist} target="_blank" class="block px-3 py-2 text-[9px] font-bold text-white hover:bg-red-600/20 transition">Artist Channel</a>
                  <a href={ytBeats} target="_blank" class="block px-3 py-2 text-[9px] font-bold text-white hover:bg-red-600/20 border-t border-white/5 transition">Beats Channel</a>
                </div>
              </div>

              <a href={socialLinks.spotify} target="_blank" class="text-[10px] font-bold uppercase text-green-500/80 hover:text-green-500 transition">Spotify</a>
              <a href={discordInvite} target="_blank" class="text-[10px] font-bold uppercase text-[#5865F2] hover:text-[#7289da] transition">Discord</a>
              <a href="#contact" class="text-[10px] font-bold uppercase text-fuchsia-100/70 hover:text-fuchsia-400 transition" data-i18n="contact.label">Contact</a>
            </nav>

            <div class="flex items-center gap-2">
               <div class="flex items-center font-bold text-[9px] border-r border-fuchsia-500/20 pr-3 mr-1">
                  <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 transition data-[active=true]:text-fuchsia-400 px-1">EN</button>
                  <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 transition data-[active=true]:text-fuchsia-400 px-1">EL</button>
               </div>

               <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600/20 border border-fuchsia-500/30 px-4 py-1.5 text-[10px] font-black uppercase text-fuchsia-300 hover:bg-fuchsia-500 hover:text-white transition">Store</a>

               <button id="mobile-menu-button" class="lg:hidden ml-1 p-1 text-fuchsia-400 focus:outline-none">
                 <svg id="burger-icon" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
                 <svg id="close-icon" class="hidden w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
               </button>
            </div>
          </div>

          <div id="mobile-menu" class="hidden lg:hidden flex-col pt-4 pb-4 border-t border-white/5 mt-3">
            <div class="flex flex-col gap-5 px-2">
              <a href="#beats" class="text-[12px] font-bold uppercase tracking-widest text-gray-300">Beats</a>
              <a href="#drumkits" class="text-[12px] font-bold uppercase tracking-widest text-gray-300">Drum Kits</a>
              
              <div class="flex flex-col">
                <button id="yt-mobile-toggle" class="flex items-center justify-between text-[12px] font-bold uppercase tracking-widest text-red-500 py-1">
                  YouTube <svg class="w-4 h-4 transition-transform" id="yt-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3"/></svg>
                </button>
                <div id="yt-mobile-content" class="hidden flex-col pl-4 gap-4 mt-4 border-l-2 border-red-500/20">
                  <a href={ytArtist} target="_blank" class="text-[11px] font-bold uppercase text-gray-400">Artist Channel</a>
                  <a href={ytBeats} target="_blank" class="text-[11px] font-bold uppercase text-gray-400">Beats Channel</a>
                </div>
              </div>

              <a href={socialLinks.spotify} target="_blank" class="text-[12px] font-bold uppercase tracking-widest text-green-500">Spotify</a>
              <a href={discordInvite} target="_blank" class="text-[12px] font-bold uppercase tracking-widest text-[#5865F2]">Discord</a>
              <a href="#contact" class="text-[12px] font-bold uppercase tracking-widest text-fuchsia-400">Contact</a>
            </div>
          </div>
        </div>
      </header>

      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      const dictionaries = i18nPayload;
      const getByPath = (obj, path) => path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj);
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        document.documentElement.lang = lang;
        localStorage.setItem("site-lang", lang);
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const value = key ? getByPath(dict, key) : null;
          if (typeof value === "string") node.innerHTML = value;
        });
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          btn.setAttribute("data-active", btn.getAttribute("data-lang-switch") === lang ? "true" : "false");
        });
      };
      const initial = localStorage.getItem("site-lang") || "en";
      applyLanguage(initial);
      document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
        btn.addEventListener("click", () => applyLanguage(btn.getAttribute("data-lang-switch")));
      });

      const menuBtn = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const burgerIcon = document.getElementById('burger-icon');
      const closeIcon = document.getElementById('close-icon');

      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        burgerIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
      });

      const ytToggle = document.getElementById('yt-mobile-toggle');
      const ytContent = document.getElementById('yt-mobile-content');
      const ytArrow = document.getElementById('yt-arrow');

      ytToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        ytContent.classList.toggle('hidden');
        ytArrow.classList.toggle('rotate-180');
      });

      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          burgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>