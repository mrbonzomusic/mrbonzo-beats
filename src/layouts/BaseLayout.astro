---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

const discordInvite = "https://discord.gg/hmpCHd4J";
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";

const siteUrl = "https://mrbonzo-beats.pages.dev/"; 
---

<!doctype html>
<html lang="en" class="scroll-smooth"> <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Official beat store and portfolio of Mr. Bonzo." />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <main class="mx-auto max-w-7xl px-4 pb-6 pt-0 sm:px-6 lg:px-8">
      
      <header class="sticky top-2 z-50 mb-4">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/80 backdrop-blur-md px-4 py-1.5 sm:px-6">
          <div class="flex items-center justify-between gap-4">
            
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[25px] w-auto sm:h-[35px]" />
            </a>

            <nav class="flex items-center gap-x-3 lg:gap-x-6">
              <a href="/" class="hidden lg:block text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="nav.home">Home</a>
              <a href="#beats" class="text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="nav.beats">Beats</a>
              
              <a href="#featured-player" class="hidden md:block text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-100/70 transition hover:text-fuchsia-400">Featured Player</a>
              
              <div class="relative group cursor-pointer">
                <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-red-500/80 transition hover:text-red-500 flex items-center gap-1">
                  YouTube <svg class="h-2 w-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                </span>
                <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute top-full left-0 mt-2 w-32 rounded-lg border border-white/10 bg-black/95 p-1 shadow-2xl transition-all">
                  <a href={ytArtist} target="_blank" class="block rounded px-3 py-2 text-[8px] font-bold uppercase text-white hover:bg-red-600/20">Artist</a>
                  <a href={ytBeats} target="_blank" class="block rounded px-3 py-2 text-[8px] font-bold uppercase text-white hover:bg-red-600/20 border-t border-white/5">Beats</a>
                </div>
              </div>

              <a href={pond5Link} target="_blank" class="hidden sm:block text-[9px] font-bold uppercase tracking-[0.2em] text-orange-500/80 transition hover:text-orange-500">Pond5</a>
              <a href={socialLinks.spotify} target="_blank" class="text-[9px] font-bold uppercase tracking-[0.2em] text-green-500/80 transition hover:text-green-500">Spotify</a>
              <a href={discordInvite} target="_blank" class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#5865F2] transition hover:text-[#7289da]">Discord</a>
            </nav>

            <div class="flex items-center gap-3">
               <div class="hidden xs:flex items-center gap-1.5 font-bold text-[8px] tracking-widest border-r border-fuchsia-500/20 pr-3 text-fuchsia-100/40">
                  <button type="button" data-lang-switch="en" class="transition data-[active=true]:text-fuchsia-400">EN</button>
                  <span>/</span>
                  <button type="button" data-lang-switch="el" class="transition data-[active=true]:text-fuchsia-400">EL</button>
               </div>
               <a href={beatstarsLinks.profile} target="_blank" class="flex-shrink-0 rounded-full bg-fuchsia-600/20 border border-fuchsia-500/30 px-3 py-1.5 text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-300 transition hover:bg-fuchsia-500 hover:text-white" data-i18n="nav.store">Store</a>
            </div>
          </div>
        </div>
      </header>

      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      const dictionaries = i18nPayload;
      const getByPath = (obj, path) => path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj);
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        document.documentElement.lang = lang;
        localStorage.setItem("site-lang", lang);
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const value = key ? getByPath(dict, key) : null;
          if (typeof value === "string") node.textContent = value;
        });
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          btn.setAttribute("data-active", btn.getAttribute("data-lang-switch") === lang ? "true" : "false");
        });
      };
      const initial = localStorage.getItem("site-lang") || "en";
      applyLanguage(initial);
      document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
        btn.addEventListener("click", () => applyLanguage(btn.getAttribute("data-lang-switch")));
      });
    </script>
  </body>
</html>