---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

// Το link του Discord που μου έστειλες
const discordInvite = "https://discord.gg/hmpCHd4J";

const siteUrl = "https://mrbonzo-beats.pages.dev/"; 
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>

    <meta name="description" content="Official beat store and portfolio of Mr. Bonzo. Dark, modern, and aggressive type beats for artists." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Dark, modern, and aggressive type beats by Mr. Bonzo." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}images/logo-main.webp`} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <main class="mx-auto max-w-7xl px-4 pb-6 pt-0 sm:px-6 lg:px-8">
      
      <header class="sticky top-2 z-50 mb-4">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/80 backdrop-blur-md px-4 py-1.5 sm:px-5">
          <div class="flex items-center justify-between gap-2 sm:gap-4">
            
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img
                src={logoPath}
                alt="Mr. Bonzo logo"
                class="h-[28px] w-auto drop-shadow-[0_0_10px_rgba(217,70,239,0.3)] sm:h-[38px]"
              />
            </a>

            <nav class="flex items-center gap-x-3 sm:gap-x-5">
              <a href="/" class="hidden md:block text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="nav.home">Home</a>
              <a href="#beats" class="text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-100/70 transition hover:text-fuchsia-400" data-i18n="nav.beats">Beats</a>
              
              <a 
                href={discordInvite}
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-[9px] font-bold uppercase tracking-[0.2em] text-[#5865F2] transition hover:text-[#7289da]"
              >
                <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 24 24">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                </svg>
                <span data-i18n="nav.discord">Discord</span>
              </a>

              <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600/20 border border-fuchsia-500/30 px-3 py-1 text-[9px] font-bold uppercase tracking-[0.2em] text-fuchsia-300 transition hover:bg-fuchsia-500 hover:text-white" data-i18n="nav.store">Store</a>
            </nav>

            <div class="flex items-center gap-2 font-bold text-[9px] tracking-widest border-l border-fuchsia-500/20 pl-4">
               <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 transition data-[active=true]:text-fuchsia-400">EN</button>
               <span class="text-fuchsia-500/20">/</span>
               <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 transition data-[active=true]:text-fuchsia-400">EL</button>
            </div>
          </div>
        </div>
      </header>

      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      const dictionaries = i18nPayload;
      const getByPath = (obj, path) => path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj);
      
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        document.documentElement.lang = lang;
        localStorage.setItem("site-lang", lang);
        
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const value = key ? getByPath(dict, key) : null;
          if (typeof value === "string") node.textContent = value;
        });
        
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          const isActive = btn.getAttribute("data-lang-switch") === lang;
          btn.setAttribute("data-active", isActive ? "true" : "false");
        });
      };

      const initial = localStorage.getItem("site-lang") || "en";
      applyLanguage(initial);
      
      document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
        btn.addEventListener("click", () => applyLanguage(btn.getAttribute("data-lang-switch") || "en"));
      });
    </script>
  </body>
</html>