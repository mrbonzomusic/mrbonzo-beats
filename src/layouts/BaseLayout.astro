---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Official" } = Astro.props;
const logoPath = "/images/logo-main.webp";

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const tikTokLink = socialLinks.tiktok || "https://www.tiktok.com/@mrbonzomusic"; 
const spotifyLink = socialLinks.spotify || "http://googleusercontent.com/spotify.com/6";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFJSZGBGZE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QFJSZGBGZE');
    </script>

    <script data-goatcounter="https://mrbonzo.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

    <style is:global>
      header#main-header {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        z-index: 9999999 !important;
        padding-top: 0.75rem;
      }
      body {
        padding-top: 90px !important;
        background-color: black;
      }
      .nav-divider {
        width: 1px; height: 14px;
        background-color: rgba(217, 70, 239, 0.3);
        margin: 0 6px; flex-shrink: 0;
      }
      .nav-dropdown {
        position: relative; display: inline-block;
        padding-bottom: 20px; margin-bottom: -20px;
      }
      .nav-dropdown-content {
        display: none; position: absolute;
        background-color: rgba(0, 0, 0, 0.95);
        min-width: 160px; box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
        z-index: 1000; border: 1px solid rgba(217, 70, 239, 0.2);
        border-radius: 14px; margin-top: 5px; backdrop-filter: blur(12px);
      }
      .nav-dropdown-content a {
        color: white; padding: 12px 16px; text-decoration: none;
        display: block; font-size: 11px; font-weight: bold;
        text-transform: uppercase; letter-spacing: 0.05em;
      }
      .nav-dropdown:hover .nav-dropdown-content {
        display: block; animation: dropdownFade 0.2s ease-out;
      }
      @keyframes dropdownFade {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
      }

      #mobile-menu.hidden { display: none; }
      .mobile-link {
        display: block; padding: 0.85rem 1rem; color: #e5e7eb;
        font-weight: 800; text-transform: uppercase;
        letter-spacing: 0.1em; font-size: 11px;
      }
    </style>
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <header id="main-header">
      <div class="mx-auto max-w-7xl px-4">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/90 backdrop-blur-md px-4 py-2.5 shadow-2xl flex items-center justify-between">
            
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[20px] w-auto sm:h-[28px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-4">
              <a href="#player" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-400 hover:text-fuchsia-300 transition">Player</a>
              <a href="#beats" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Beats</a>
              <a href={spotifyLink} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Spotify</a>
              <a href={discordInvite} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Discord</a>
            </nav>

            <div class="flex items-center gap-1 sm:gap-3">
               
               <div class="flex items-center gap-0.5 font-bold text-[9px] sm:text-[10px] border-r border-fuchsia-500/20 pr-2 sm:pr-3 mr-1">
                  <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-400 px-1 transition">EN</button>
                  <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-400 px-1 transition">EL</button>
               </div>

               <button id="share-btn" class="p-1.5 text-fuchsia-400 hover:text-fuchsia-300 active:scale-90 transition-all" aria-label="Share">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                </svg>
               </button>

               <a href={beatstarsLinks.profile} target="_blank" class="hidden xs:block rounded-full bg-fuchsia-600 px-3 py-1.5 text-[9px] sm:text-[10px] font-black uppercase text-white hover:bg-fuchsia-500 transition">Store</a>
               
               <button id="burger-btn" class="lg:hidden p-1 text-fuchsia-400">
                 <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                   <path d="M4 6h16M4 12h16m-7 6h7"/>
                 </svg>
               </button>
            </div>
        </div>

        <div id="mobile-menu" class="hidden lg:hidden mt-2">
          <div class="rounded-3xl border border-fuchsia-500/20 bg-black/95 backdrop-blur-xl p-2 shadow-2xl overflow-hidden">
            <a href="#player" class="mobile-link text-fuchsia-400">Player</a>
            <a href="#beats" class="mobile-link">Beats</a>
            <a href="#drumkits" class="mobile-link">Drum Kits</a>
            <a href={beatstarsLinks.profile} target="_blank" class="mobile-link text-fuchsia-600 font-black border-t border-white/5">Open Store</a>
            <a href={spotifyLink} target="_blank" class="mobile-link opacity-70">Spotify</a>
            <a href={discordInvite} target="_blank" class="mobile-link opacity-70">Discord</a>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4">
      <slot />
    </main>

    <script is:inline>
      // BURGER
      const bBtn = document.getElementById('burger-btn');
      const mMenu = document.getElementById('mobile-menu');
      if (bBtn && mMenu) {
        bBtn.addEventListener('click', (e) => { e.stopPropagation(); mMenu.classList.toggle('hidden'); });
        document.addEventListener('click', (e) => { if (!mMenu.contains(e.target) && !bBtn.contains(e.target)) mMenu.classList.add('hidden'); });
      }

      // SHARE
      const shareBtn = document.getElementById('share-btn');
      if (shareBtn) {
        shareBtn.addEventListener('click', async () => {
          if (navigator.share) {
            try { await navigator.share({ title: 'Mr. Bonzo', url: window.location.href }); } catch (err) {}
          } else {
            navigator.clipboard.writeText(window.location.href);
            alert('Link copied!');
          }
        });
      }
    </script>
  </body>
</html>