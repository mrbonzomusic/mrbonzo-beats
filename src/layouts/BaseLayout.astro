---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Official" } = Astro.props;
const logoPath = "/images/logo-main.webp";

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const tikTokLink = "https://www.tiktok.com/@mrbonzomusic"; 
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const spotifyLink = socialLinks.spotify || "http://googleusercontent.com/spotify.com/6";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFJSZGBGZE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QFJSZGBGZE');
    </script>

    <script data-goatcounter="https://mrbonzo.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

    <style is:global>
      header#main-header {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        z-index: 9999999 !important;
        padding-top: 0.75rem;
      }
      body {
        padding-top: 90px !important;
        background-color: black;
      }
      .nav-divider {
        width: 1px; height: 14px;
        background-color: rgba(217, 70, 239, 0.3);
        margin: 0 6px; flex-shrink: 0;
      }
      /* Dropdown Styles */
      .nav-dropdown { position: relative; display: inline-block; }
      .nav-dropdown-content {
        display: none; position: absolute;
        background-color: rgba(0, 0, 0, 0.95);
        min-width: 160px; border: 1px solid rgba(217, 70, 239, 0.2);
        border-radius: 14px; backdrop-filter: blur(12px);
      }
      .nav-dropdown:hover .nav-dropdown-content { display: block; }
    </style>
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <header id="main-header">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/90 backdrop-blur-md px-5 py-2.5 shadow-2xl">
          <div class="flex items-center justify-between">
            <a href="/" class="flex-shrink-0 transition hover:scale-105">
              <img src={logoPath} alt="Logo" class="h-[22px] w-auto sm:h-[30px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-3 xl:gap-x-4">
              <a href="#player" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-400 hover:text-fuchsia-300 transition">Player</a>
              <a href="#beats" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Beats</a>
              <a href="#drumkits" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Kits</a>
              <div class="nav-divider"></div>
              <a href={spotifyLink} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Spotify</a>
              <a href={discordInvite} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-100/70 hover:text-fuchsia-400 transition">Discord</a>
            </nav>

            <div class="flex items-center gap-2">
               <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600 px-4 py-1.5 text-[10px] font-black uppercase text-white hover:bg-fuchsia-500 transition">Store</a>
               
               <button id="burger-btn" class="lg:hidden p-1 text-fuchsia-400 focus:outline-none">
                 <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7"/>
                 </svg>
               </button>
            </div>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="hidden lg:hidden mx-auto max-w-7xl px-4 mt-2">
        <div class="rounded-3xl border border-fuchsia-500/20 bg-black/95 backdrop-blur-xl p-6 shadow-2xl flex flex-col gap-4">
          <a href="#player" class="mobile-link text-fuchsia-400">Player</a>
          <a href="#beats" class="mobile-link">Beats</a>
          <a href="#drumkits" class="mobile-link">Drum Kits</a>
          <div class="h-px bg-white/10 w-full"></div>
          <a href={ytBeats} target="_blank" class="mobile-link">YouTube Beats</a>
          <a href={spotifyLink} target="_blank" class="mobile-link">Spotify</a>
          <a href={discordInvite} target="_blank" class="mobile-link">Discord</a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <style>
      .mobile-link {
        @apply text-[14px] font-black uppercase tracking-widest py-2 border-b border-white/5;
      }
    </style>

    <script is:inline>
      const bBtn = document.getElementById('burger-btn');
      const mMenu = document.getElementById('mobile-menu');

      bBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        mMenu?.classList.toggle('hidden');
      });

      // Κλείσιμο όταν κάνεις κλικ σε link
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => mMenu?.classList.add('hidden'));
      });

      // Κλείσιμο αν κάνεις κλικ έξω από το μενού
      document.addEventListener('click', (e) => {
        if (!mMenu?.contains(e.target) && !bBtn?.contains(e.target)) {
          mMenu?.classList.add('hidden');
        }
      });
    </script>
  </body>
</html>