---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CollaborationsSection from "../components/CollaborationsSection.astro";
import TypeBeatGrid from "../components/TypeBeatGrid.astro";
import FeaturedBeatstars from "../components/FeaturedBeatstars.astro";
import DrumKits from "../components/DrumKits.astro";
import DiscographySection from "../components/DiscographySection.astro";
import AboutSection from "../components/AboutSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import ContactSection from "../components/ContactSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getArtistAlbums, extractSpotifyArtistId, getReleasesFromRss, getReleasesFromSpotifyPage, sortReleasesNewestFirst } from "../lib/spotify";
import { socialLinks } from "../config/links";

// ΕΙΣΑΓΩΓΗ ΓΛΩΣΣΩΝ

const fallbackCover = "/images/logo-main.webp";

/** Pinned so the newest release stays visible even if API/scrape lag. */
const pinnedReleases = [
  {
    title: "Catalyst (Beat Tape)",
    year: "2026",
    cover: "https://i.scdn.co/image/ab67616d0000b273b7b262b891485d0c7e9a4f0f",
    spotify: "https://open.spotify.com/album/7GiFC2kGwZDjZ9Nnwoqxn6",
    releaseDate: "2026-07-01",
  },
];

function withPinnedReleases(data) {
  const list = Array.isArray(data?.releases) ? data.releases : [];
  const seen = new Set();
  const merged = [];
  for (const release of [...pinnedReleases, ...list]) {
    const key = release?.spotify || release?.title;
    if (!key || seen.has(key)) continue;
    seen.add(key);
    merged.push(release);
  }
  return { ...data, releases: sortReleasesNewestFirst(merged).slice(0, 6) };
}

// Primary: Spotify Web API (date-sorted). Fallbacks: RSS → public page scrape.
let spotifyData = await getArtistAlbums({
  clientId: import.meta.env.SPOTIFY_CLIENT_ID,
  clientSecret: import.meta.env.SPOTIFY_CLIENT_SECRET,
  artistId: import.meta.env.SPOTIFY_ARTIST_ID || extractSpotifyArtistId(socialLinks.spotify),
  fallbackCover,
});

if (!(spotifyData.status === "live" && spotifyData.releases.length > 0)) {
  const rssData = await getReleasesFromRss({
    feedUrl: import.meta.env.RELEASES_RSS_URL,
    fallbackCover,
  });

  spotifyData =
    rssData.status === "rss" && rssData.releases.length > 0
      ? rssData
      : await getReleasesFromSpotifyPage({
          artistUrl: socialLinks.spotify,
          fallbackCover,
        });
}

spotifyData = withPinnedReleases(spotifyData);
---

<BaseLayout title="Mr. Bonzo | Official Website">
  
  <Hero />

  <CollaborationsSection />

  <section id="player" class="section-reveal scroll-mt-24">
    <FeaturedBeatstars />
  </section>

  <section id="beats" class="section-reveal scroll-mt-24">
    <TypeBeatGrid />
  </section>

  <section id="drumkits" class="section-reveal scroll-mt-24">
    <DrumKits />
  </section>

  <section id="latest-releases" class="section-reveal scroll-mt-24">
    <DiscographySection releases={spotifyData.releases} status={spotifyData.status} />
  </section>

  <section id="about" class="section-reveal scroll-mt-24">
    <AboutSection />
    <ServicesSection />
  </section>
  
  <section id="contact" class="section-reveal scroll-mt-24">
    <ContactSection /> 
  </section>

  <SiteFooter />

</BaseLayout>
