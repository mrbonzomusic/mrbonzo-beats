# Spotify Web API (preferred for Latest Releases at build time)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional — defaults to artist id parsed from src/config/links.ts socialLinks.spotify
# SPOTIFY_ARTIST_ID=5ziH2Z9Gl3M1FhcYvrLHpv

# Optional RSS fallback if API credentials are missing
# RELEASES_RSS_URL=
